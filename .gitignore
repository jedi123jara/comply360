# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# scratch / handoff bundles (Claude Design exports, favicon trials, etc.)
.design-temp/
favicons_temporales/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# Plantillas públicas SIN secrets — deben commitearse
!.env.example

# Archivos con secrets locales (no commitear)
VERCEL_ENV_IMPORT.txt
SUPABASE_PASSWORD.txt

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# uploaded files (local dev storage)
/public/uploads

.vercel

# Python cache (skill scripts en .claude/)
__pycache__/
*.pyc
*.pyo
