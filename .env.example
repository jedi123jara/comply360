# =============================================
# COMPLY360 - Environment Variables
# Copy this file to .env and fill in the values
# =============================================

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Database (PostgreSQL — Supabase recommended)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Supabase Storage (optional — for file uploads in production)
# Get these from: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project.supabase.com
SUPABASE_SERVICE_KEY=your-service-role-key-here
# Bucket: Create a bucket named "worker-documents" in Supabase Storage
# Set bucket policy to "authenticated" for security

# =============================================
# IA Multi-modelo (estrategia recomendada para Comply360)
# =============================================
# Combinación óptima costo/calidad por feature:
#   - DeepSeek V4 Flash → chat copilot, generadores, plan acción (más barato)
#   - DeepSeek V4 Pro   → revisión de contratos (calidad Sonnet a 7x menos costo)
#   - Anthropic Opus    → contract-fix high-stakes (máxima precisión legal)
#   - OpenAI gpt-4o-mini vision → document-verify (DeepSeek no tiene vision)
#
# Auto-detect priority: DeepSeek > Anthropic > Groq > OpenAI > Ollama.
# Si solo configuras una, todas las features la usan.

# ═════════════════════════════════════════════════════════════════════════
# COMPLY360 — Capa de IA (DeepSeek primario, OpenAI excepción quirúrgica)
# ═════════════════════════════════════════════════════════════════════════
#
# Arquitectura definitiva: TODO el routing IA va a DeepSeek V4 (Flash o Pro
# según feature). OpenAI se mantiene SOLO para 2 features que DeepSeek no
# soporta competitivamente:
#   - vision (Fase 3.5: auto-verify de DNI/CV/exámenes médicos)
#   - embeddings RAG (text-embedding-3-small)
#
# Ver src/lib/ai/feature-routing.ts para el mapping completo declarativo.
# ─────────────────────────────────────────────────────────────────────────

# DeepSeek (REQUERIDO — motor único del producto)
# Crear cuenta: https://platform.deepseek.com/api_keys
# Recarga inicial sugerida: $5 USD (con context caching te dura 2-4 meses)
DEEPSEEK_API_KEY=sk-xxxxx
# Modelos: deepseek-chat (V4 Flash) | deepseek-reasoner (V4 Pro). El tier por
# feature se resuelve automáticamente vía FEATURE_ROUTING. NO necesitas tocar
# DEEPSEEK_MODEL salvo que quieras forzar globalmente (no recomendado).
# DEEPSEEK_MODEL=deepseek-chat

# OpenAI (REQUERIDO solo para vision + embeddings)
# Crear cuenta: https://platform.openai.com/api-keys
# Recarga sugerida: $5-10 USD/mes (volumen de Fase 3.5 + RAG ingest es bajo)
OPENAI_API_KEY=sk-xxxxx

# ── Overrides opcionales por feature ─────────────────────────────────────
# Patrón: <FEATURE>_AI_PROVIDER (cambia el provider) o <FEATURE>_TIER (Flash/Pro)
# Útil para A/B testing o rollback selectivo sin redeploy.
# Features tier flash: chat, worker-chat, complaint-triage, norm-classifier, pdf-extract, doc-generator
# Features tier pro:   contract-review, contract-gen, contract-fix, action-plan, pliego-analysis, sunafil-agent, payslip-audit, descargo-writer
#
# Ejemplos:
# CONTRACT_REVIEW_TIER=flash                    # Bajar a Flash si Pro es muy caro
# CHAT_AI_PROVIDER=openai                       # Forzar OpenAI en chat para A/B
# CONTRACT_REVIEW_DEEPSEEK_MODEL=deepseek-chat  # Override directo del modelo

# ── Capacity guards ──────────────────────────────────────────────────────
# Cap de llamadas IA por hora por organización (anti-abuso). Default: 1000.
# AI_HOURLY_CALL_LIMIT=1000

# ── Rollout staged (soft launch de DeepSeek) ─────────────────────────────
# Porcentaje del tráfico que va a DeepSeek; resto cae al fallback (OpenAI).
# Usar para subir gradualmente: 10 → 25 → 50 → 100. Bucketing estable por org.
# Default (vacío) = 100 (DeepSeek pleno).
# AI_ROLLOUT_PERCENTAGE=10

# ── Anthropic (DEPRECATED — mantener vacío, solo por compat) ─────────────
# El código sigue soportando Anthropic como override per-feature pero el
# producto no lo usa por default. Si lo activas, override explícito por feature.
# ANTHROPIC_API_KEY=

# ── Groq (DEPRECATED — mantener vacío, solo por compat) ──────────────────
# GROQ_API_KEY=

# Culqi Payments (Peru)
CULQI_PUBLIC_KEY=pk_test_xxxxx
CULQI_SECRET_KEY=sk_test_xxxxx

# Resend Email (optional — notifications)
RESEND_API_KEY=re_xxxxx

# WhatsApp Business Cloud API (optional — alertas vía WhatsApp)
# Obtener en https://developers.facebook.com/apps → tu app → WhatsApp → API Setup
# El token permanente se genera en Meta Business Settings > System Users (no el temporal de 24h).
# El Phone Number ID es el del número Business verificado, NO el número en sí.
# Si falta alguno, el canal whatsapp se ignora silenciosamente (no rompe otros canales).
WHATSAPP_BUSINESS_TOKEN=EAAxxxxx
WHATSAPP_PHONE_NUMBER_ID=1234567890

# Cron Security
CRON_SECRET=your-random-secret-here

# =============================================
# Founder Console (SUPER_ADMIN only — tuyo, no de los clientes)
# =============================================
# Email donde llega el Daily Digest cada mañana 8am Lima con MRR, signups,
# churn risks, etc. Si no se setea, el cron se salta el envío sin romperse.
FOUNDER_EMAIL=tu@email.com
# Incoming webhook de Slack (opcional pero altamente recomendado). Se usa
# para pings en tiempo real: nuevos signups, pagos, churn risks, digest.
# Crearlo en: https://api.slack.com/messaging/webhooks
SLACK_FOUNDER_WEBHOOK_URL=

# Sentry Error Tracking (optional)
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@o0.ingest.sentry.io/0
SENTRY_AUTH_TOKEN=sntrys_xxxxx

# reCAPTCHA v3 (optional — anti-bot)
RECAPTCHA_SECRET_KEY=6Lxxxxx

# SUNAT/RENIEC Integration (apis.net.pe)
# Obtén tu token en: https://apis.net.pe/panel (plan gratuito disponible)
# Permite consultar RUC (SUNAT) y DNI (RENIEC) automáticamente.
# Sin este token, la plataforma usa datos simulados en desarrollo.
APIS_NET_PE_TOKEN=your-token-here

# JWT Secret (for signature tokens)
JWT_SECRET=your-random-jwt-secret-32-chars-minimum

# =============================================
# Worker Bulk Import — token signing (FIX #1.D)
# =============================================
# El POST de /api/workers/import devuelve un token con los datos parseados;
# el PUT lo verifica antes de crear los workers en bulk. SIN esta clave, en
# producción el endpoint falla; en dev usa fallback determinístico.
# Generar con: openssl rand -base64 32   (mínimo 32 chars)
IMPORT_TOKEN_SECRET=

# =============================================
# RLS Postgres enforcement (FIX #1.B)
# =============================================
# Cuando true, runWithOrgScope() ejecuta SET LOCAL app.current_org_id antes
# de cada query envuelta. Requiere que el rol de la conexión Prisma NO tenga
# BYPASSRLS y que las policies de prisma/rls-policies.sql estén aplicadas.
# Mantener en false hasta completar la Ola 1.B (refactor de handlers
# críticos a runWithOrgScope). Default false.
# RLS_ENFORCED=false

# =============================================
# WebAuthn enrolment-strict (FIX #1.A)
# =============================================
# Cuando true, las firmas BIOMETRIC requieren un credential previamente
# registrado del worker (verificación con verifyAndUpdateAuthentication).
# Mantener en false hasta cablear el flow de enrolment en BiometricCeremonyModal
# y que los workers existentes hayan registrado al menos una passkey.
# WEBAUTHN_STRICT_VERIFY=false

# =============================================
# MEDICAL VAULT (Fase 5 — SST Premium, Ley 29733 + D.S. 016-2024-JUS)
# =============================================
# Clave maestra para cifrar columnas médicas con pgcrypto.pgp_sym_encrypt:
#   - EMO.restriccionesCifrado
#   - ConsentimientoLey29733.textoCifrado / firmaCifrada
#   - SolicitudARCO.detalleCifrado
#
# Generar con: openssl rand -base64 32
# Mínimo 32 caracteres. Si falta en producción, el boot falla rápido.
# En dev se usa una clave de fallback con warning en consola.
MEDICAL_VAULT_KEY=

# Twilio SMS (optional — critical alerts)
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_PHONE_NUMBER=+1xxxxx

# Plausible Analytics (opcional pero recomendado — GDPR-friendly, sin cookies)
# Registrate en https://plausible.io → añade tu dominio → copia el data-domain.
# Si no está configurado, los eventos se loguean a consola en dev y se
# silencian en prod (no rompe nada).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# NEXT_PUBLIC_PLAUSIBLE_SRC=  # Solo si self-hostás (default: plausible.io/js/script.tagged-events.js)

# Web Push Notifications (Fase D — opcional pero recomendado)
# Genera un par VAPID con: npx web-push generate-vapid-keys
# La clave pública SE EXPONE al browser vía /api/notifications/vapid-key.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:alerts@comply360.pe

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
