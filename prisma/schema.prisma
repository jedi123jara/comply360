generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================
// AUTHENTICATION & ORGANIZATIONS
// =============================================

model Organization {
  id                  String    @id @default(cuid())
  name                String
  ruc                 String?   @unique
  razonSocial         String?   @map("razon_social")
  nombreComercial     String?   @map("nombre_comercial")
  sector              String?
  sizeRange           String?   @map("size_range") // 1-10, 11-50, 51-200, 200+
  logoUrl             String?   @map("logo_url")
  plan                Plan      @default(STARTER)
  planExpiresAt       DateTime? @map("plan_expires_at")
  onboardingCompleted Boolean   @default(false) @map("onboarding_completed")
  regimenPrincipal    String?   @map("regimen_principal") // GENERAL, MYPE_MICRO, etc.
  regimenTributario   String?   @map("regimen_tributario") // RER, RMT, RG, RUS
  alertEmail          String?   @map("alert_email")
  phone               String?
  address             String? // direccion fiscal
  city                String? // departamento
  province            String?
  district            String?
  // Representante Legal
  repNombre           String?   @map("rep_nombre")
  repDni              String?   @map("rep_dni")
  repCargo            String?   @map("rep_cargo")
  // Contador responsable
  contNombre          String?   @map("cont_nombre")
  contCpc             String?   @map("cont_cpc")
  contEmail           String?   @map("cont_email")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  users                  User[]
  workers                Worker[]
  contracts              Contract[]
  calculations           Calculation[]
  orgAlerts              OrgAlert[]
  auditLogs              AuditLog[]
  subscription           Subscription?
  diagnostics            ComplianceDiagnostic[]
  complianceTasks        ComplianceTask[]
  complaints             Complaint[]
  invitations            Invitation[]
  payslips               Payslip[]
  workerRequests         WorkerRequest[]
  documents              OrgDocument[]
  serviceProviders       ServiceProvider[]
  rhInvoices             RhInvoice[]
  inspecciones           InspeccionEnVivo[]
  ownedClients           ConsultorClient[]       @relation("ConsultorOwner")
  managedBy              ConsultorClient[]       @relation("ConsultorManaged")
  integrationCredentials IntegrationCredential[]

  @@map("organizations")
}

// Credenciales de integración encriptadas (SUNAT SOL, etc.)
model IntegrationCredential {
  id              String    @id @default(cuid())
  orgId           String    @map("org_id")
  provider        String // "sunat_sol", "sunat_api", etc.
  label           String? // "SUNAT RUC 20505897867"
  encryptedConfig String    @map("encrypted_config") @db.Text // JSON encriptado con AES-256-GCM
  isActive        Boolean   @default(true) @map("is_active")
  lastTestedAt    DateTime? @map("last_tested_at")
  lastSyncAt      DateTime? @map("last_sync_at")
  lastSyncResult  Json?     @map("last_sync_result") // { success, discrepancies, timestamp }
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, provider])
  @@map("integration_credentials")
}

enum Plan {
  FREE
  STARTER
  EMPRESA
  PRO
  ENTERPRISE
}

model User {
  id               String    @id @default(cuid())
  clerkId          String    @unique @map("clerk_id")
  orgId            String?   @map("org_id")
  email            String    @unique
  firstName        String?   @map("first_name")
  lastName         String?   @map("last_name")
  role             UserRole  @default(MEMBER)
  avatarUrl        String?   @map("avatar_url")
  // Web Push subscription (Fase D). JSON con { endpoint, keys.p256dh, keys.auth }.
  pushSubscription Json?     @map("push_subscription")
  // Gamificación — Fase D Sprint 5
  streakCurrent    Int       @default(0) @map("streak_current")
  streakLongest    Int       @default(0) @map("streak_longest")
  streakLastAt     DateTime? @map("streak_last_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  organization       Organization?       @relation(fields: [orgId], references: [id])
  worker             Worker? // Si el User tiene rol WORKER, su perfil de trabajador
  contracts          Contract[]          @relation("CreatedBy")
  calculations       Calculation[]
  auditLogs          AuditLog[]
  workerRequests     WorkerRequest[]     @relation("RequestReviewer")
  gamificationEvents GamificationEvent[]

  @@map("users")
}

// Gamificación — eventos que suman puntos y desbloquean logros
model GamificationEvent {
  id        String                @id @default(cuid())
  userId    String                @map("user_id")
  orgId     String?               @map("org_id")
  type      GamificationEventType
  points    Int                   @default(0)
  metadata  Json?
  createdAt DateTime              @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([orgId, type])
  @@map("gamification_events")
}

enum GamificationEventType {
  WORKER_CREATED
  DOCUMENT_UPLOADED
  ALERT_RESOLVED
  DIAGNOSTIC_COMPLETED
  SIMULACRO_COMPLETED
  CONTRACT_SIGNED
  DAILY_STREAK
  BADGE_UNLOCKED
  SCORE_MILESTONE
}

enum UserRole {
  SUPER_ADMIN // Dueños de la plataforma — acceso global a todas las organizaciones
  OWNER // Dueño de la organización (empresa cliente)
  ADMIN // Administrador con permisos amplios dentro de la org
  MEMBER // Miembro con acceso operativo
  VIEWER // Solo lectura
  WORKER // Trabajador con acceso a su portal personal (sin acceso al dashboard de gestión)
}

model Invitation {
  id        String   @id @default(cuid())
  orgId     String   @map("org_id")
  email     String
  role      UserRole @default(MEMBER)
  token     String   @unique
  status    String   @default("PENDING")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, email])
  @@map("invitations")
}

// =============================================
// WORKERS (FASE 1 — Modulo central)
// =============================================

model Worker {
  id                 String         @id @default(cuid())
  orgId              String         @map("org_id")
  userId             String?        @unique @map("user_id") // Opcional — vincula con User cuando el trabajador activa su portal
  // Datos personales
  dni                String
  firstName          String         @map("first_name")
  lastName           String         @map("last_name")
  email              String?
  phone              String?
  birthDate          DateTime?      @map("birth_date")
  gender             String?
  nationality        String?        @default("peruana")
  address            String?
  // Datos laborales
  position           String?
  department         String?
  regimenLaboral     RegimenLaboral @default(GENERAL) @map("regimen_laboral")
  tipoContrato       TipoContrato   @default(INDEFINIDO) @map("tipo_contrato")
  fechaIngreso       DateTime       @map("fecha_ingreso")
  fechaCese          DateTime?      @map("fecha_cese")
  motivoCese         String?        @map("motivo_cese")
  sueldoBruto        Decimal        @map("sueldo_bruto") @db.Decimal(10, 2)
  asignacionFamiliar Boolean        @default(false) @map("asignacion_familiar")
  jornadaSemanal     Int            @default(48) @map("jornada_semanal")
  tiempoCompleto     Boolean        @default(true) @map("tiempo_completo")
  // Previsional
  tipoAporte         TipoAporte     @default(AFP) @map("tipo_aporte")
  afpNombre          String?        @map("afp_nombre")
  cuspp              String?
  essaludVida        Boolean        @default(false) @map("essalud_vida")
  sctr               Boolean        @default(false)
  // Estado
  status             WorkerStatus   @default(ACTIVE)
  legajoScore        Int?           @map("legajo_score")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  organization    Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user            User?            @relation(fields: [userId], references: [id])
  documents       WorkerDocument[]
  workerContracts WorkerContract[]
  vacations       VacationRecord[]
  alerts          WorkerAlert[]
  attendance      Attendance[]
  payslips        Payslip[]
  requests        WorkerRequest[]
  ceseRecord      CeseRecord?

  @@unique([orgId, dni])
  @@index([orgId, status])
  @@index([orgId, regimenLaboral])
  @@map("workers")
}

enum RegimenLaboral {
  GENERAL
  MYPE_MICRO
  MYPE_PEQUENA
  AGRARIO
  CONSTRUCCION_CIVIL
  MINERO
  PESQUERO
  TEXTIL_EXPORTACION
  DOMESTICO
  CAS
  MODALIDAD_FORMATIVA
  TELETRABAJO
}

enum TipoContrato {
  INDEFINIDO
  PLAZO_FIJO
  TIEMPO_PARCIAL
  INICIO_ACTIVIDAD
  NECESIDAD_MERCADO
  RECONVERSION
  SUPLENCIA
  EMERGENCIA
  OBRA_DETERMINADA
  INTERMITENTE
  EXPORTACION
}

enum TipoAporte {
  AFP
  ONP
  SIN_APORTE
}

enum WorkerStatus {
  ACTIVE
  ON_LEAVE
  SUSPENDED
  TERMINATED
}

model WorkerDocument {
  id           String      @id @default(cuid())
  workerId     String      @map("worker_id")
  category     DocCategory
  documentType String      @map("document_type")
  title        String
  fileUrl      String?     @map("file_url")
  fileSize     Int?        @map("file_size")
  mimeType     String?     @map("mime_type")
  isRequired   Boolean     @default(false) @map("is_required")
  expiresAt    DateTime?   @map("expires_at")
  verifiedAt   DateTime?   @map("verified_at")
  verifiedBy   String?     @map("verified_by")
  status       DocStatus   @default(PENDING)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId, category])
  @@index([expiresAt])
  @@map("worker_documents")
}

enum DocCategory {
  INGRESO
  VIGENTE
  SST
  PREVISIONAL
  CESE
}

enum DocStatus {
  PENDING
  UPLOADED
  VERIFIED
  EXPIRED
  MISSING
}

model VacationRecord {
  id               String    @id @default(cuid())
  workerId         String    @map("worker_id")
  periodoInicio    DateTime  @map("periodo_inicio")
  periodoFin       DateTime  @map("periodo_fin")
  diasCorresponden Int       @default(30) @map("dias_corresponden")
  diasGozados      Int       @default(0) @map("dias_gozados")
  diasPendientes   Int       @default(30) @map("dias_pendientes")
  fechaGoce        DateTime? @map("fecha_goce")
  esDoble          Boolean   @default(false) @map("es_doble")
  createdAt        DateTime  @default(now()) @map("created_at")

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId])
  @@map("vacation_records")
}

model WorkerContract {
  id         String   @id @default(cuid())
  workerId   String   @map("worker_id")
  contractId String   @map("contract_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  worker   Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  contract Contract @relation(fields: [contractId], references: [id])

  @@unique([workerId, contractId])
  @@index([workerId])
  @@index([contractId])
  @@map("worker_contracts")
}

model WorkerAlert {
  id            String          @id @default(cuid())
  workerId      String          @map("worker_id")
  orgId         String          @map("org_id")
  type          WorkerAlertType
  severity      AlertSeverity
  title         String
  description   String?
  dueDate       DateTime?       @map("due_date")
  multaEstimada Decimal?        @map("multa_estimada") @db.Decimal(10, 2)
  resolvedAt    DateTime?       @map("resolved_at")
  resolvedBy    String?         @map("resolved_by")
  createdAt     DateTime        @default(now()) @map("created_at")

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([orgId, severity])
  @@index([orgId, resolvedAt]) // hot path: filtro resolvedAt IS NULL (12 archivos)
  @@index([dueDate])
  @@map("worker_alerts")
}

enum WorkerAlertType {
  CONTRATO_POR_VENCER
  CONTRATO_VENCIDO
  CTS_PENDIENTE
  GRATIFICACION_PENDIENTE
  VACACIONES_ACUMULADAS
  VACACIONES_DOBLE_PERIODO
  DOCUMENTO_FALTANTE
  DOCUMENTO_VENCIDO
  DOCUMENTO_SOSPECHOSO  // IA visión detectó posible manipulación
  EXAMEN_MEDICO_VENCIDO
  CAPACITACION_PENDIENTE
  AFP_EN_MORA
  REGISTRO_INCOMPLETO
}

enum AlertSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

// =============================================
// CONTRACTS
// =============================================

model ContractTemplate {
  id            String       @id @default(cuid())
  type          ContractType
  name          String
  description   String?
  version       Int          @default(1)
  fieldsSchema  Json         @map("fields_schema") // JSON Schema for dynamic form
  contentBlocks Json         @map("content_blocks") // Template blocks with variables
  legalBasis    String?      @map("legal_basis") // "D.Leg 728, Art. 4"
  isActive      Boolean      @default(true) @map("is_active")
  validFrom     DateTime     @default(now()) @map("valid_from")
  validTo       DateTime?    @map("valid_to")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  contracts Contract[]

  @@map("contract_templates")
}

enum ContractType {
  LABORAL_INDEFINIDO
  LABORAL_PLAZO_FIJO
  LABORAL_TIEMPO_PARCIAL
  LOCACION_SERVICIOS
  CONFIDENCIALIDAD
  NO_COMPETENCIA
  POLITICA_HOSTIGAMIENTO
  POLITICA_SST
  REGLAMENTO_INTERNO
  ADDENDUM
  CONVENIO_PRACTICAS
  CUSTOM
}

model Contract {
  id           String         @id @default(cuid())
  orgId        String         @map("org_id")
  createdById  String         @map("created_by_id")
  templateId   String?        @map("template_id")
  type         ContractType
  status       ContractStatus @default(DRAFT)
  title        String
  formData     Json?          @map("form_data") // User inputs
  contentJson  Json?          @map("content_json") // Generated contract structure
  contentHtml  String?        @map("content_html") // Rendered HTML
  docxUrl      String?        @map("docx_url")
  pdfUrl       String?        @map("pdf_url")
  expiresAt    DateTime?      @map("expires_at")
  signedAt     DateTime?      @map("signed_at")
  aiRiskScore  Int?           @map("ai_risk_score") // 0-100
  aiRisksJson  Json?          @map("ai_risks_json") // Array of detected risks
  aiReviewedAt DateTime?      @map("ai_reviewed_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  organization    Organization      @relation(fields: [orgId], references: [id])
  createdBy       User              @relation("CreatedBy", fields: [createdById], references: [id])
  template        ContractTemplate? @relation(fields: [templateId], references: [id])
  workerContracts WorkerContract[]

  @@index([orgId, status])
  @@index([orgId, type])
  @@index([orgId, expiresAt]) // calendar queries por fecha en ventana
  @@index([expiresAt])
  @@map("contracts")
}

enum ContractStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  SIGNED
  EXPIRED
  ARCHIVED
}

// =============================================
// LEGAL ENGINE: NORMS & RULES
// =============================================

model LegalNorm {
  id          String       @id @default(cuid())
  code        String       @unique // "DL-728", "LEY-29783"
  title       String
  bodyText    String?      @map("body_text")
  category    NormCategory
  publishedAt DateTime?    @map("published_at")
  effectiveAt DateTime?    @map("effective_at")
  repealedAt  DateTime?    @map("repealed_at")
  sourceUrl   String?      @map("source_url")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  rules  LegalRule[]
  alerts NormAlert[]

  @@index([category])
  @@map("legal_norms")
}

enum NormCategory {
  LABORAL
  SUNAFIL
  SEGURIDAD_SALUD
  TRIBUTARIO
  PROCESAL
  GENERAL
}

model LegalRule {
  id            String     @id @default(cuid())
  normId        String     @map("norm_id")
  ruleKey       String     @unique @map("rule_key") // "indemnizacion_despido_arbitrario"
  description   String?
  conditionJson Json?      @map("condition_json") // When this rule applies
  formula       String? // "sueldo * 1.5 * anos"
  parameters    Json? // { "tope_anos": 12, "factor": 1.5 }
  outputType    RuleOutput @default(NUMBER) @map("output_type")
  validFrom     DateTime   @default(now()) @map("valid_from")
  validTo       DateTime?  @map("valid_to")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  norm LegalNorm @relation(fields: [normId], references: [id])

  @@index([ruleKey])
  @@map("legal_rules")
}

enum RuleOutput {
  NUMBER
  BOOLEAN
  PERCENTAGE
  TEXT
  CLAUSE
}

// =============================================
// CALCULATIONS
// =============================================

model Calculation {
  id          String          @id @default(cuid())
  orgId       String?         @map("org_id")
  userId      String?         @map("user_id")
  type        CalculationType
  inputsJson  Json            @map("inputs_json")
  resultJson  Json            @map("result_json") // Full breakdown
  totalAmount Decimal?        @map("total_amount") @db.Decimal(12, 2)
  pdfUrl      String?         @map("pdf_url")
  isPublic    Boolean         @default(false) @map("is_public") // Free calc (no auth)
  createdAt   DateTime        @default(now()) @map("created_at")

  organization Organization? @relation(fields: [orgId], references: [id])
  user         User?         @relation(fields: [userId], references: [id])

  @@index([orgId, type])
  @@index([createdAt])
  @@map("calculations")
}

enum CalculationType {
  LIQUIDACION
  CTS
  GRATIFICACION
  INDEMNIZACION
  HORAS_EXTRAS
  VACACIONES
  MULTA_SUNAFIL
  INTERESES_LEGALES
  APORTES_PREVISIONALES
  UTILIDADES
}

// =============================================
// ALERTS
// =============================================

model NormAlert {
  id                    String         @id @default(cuid())
  normId                String         @map("norm_id")
  title                 String
  summary               String
  impactLevel           ImpactLevel    @map("impact_level")
  affectedContractTypes ContractType[] @map("affected_contract_types")
  publishedAt           DateTime       @default(now()) @map("published_at")
  createdAt             DateTime       @default(now()) @map("created_at")

  norm      LegalNorm  @relation(fields: [normId], references: [id])
  orgAlerts OrgAlert[]

  @@index([impactLevel, publishedAt])
  @@map("norm_alerts")
}

enum ImpactLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model OrgAlert {
  id          String      @id @default(cuid())
  orgId       String      @map("org_id")
  normAlertId String      @map("norm_alert_id")
  status      AlertStatus @default(UNREAD)
  createdAt   DateTime    @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id])
  normAlert    NormAlert    @relation(fields: [normAlertId], references: [id])

  @@unique([orgId, normAlertId])
  @@map("org_alerts")
}

enum AlertStatus {
  UNREAD
  READ
  DISMISSED
}

// =============================================
// SUBSCRIPTIONS & PAYMENTS
// =============================================

model Subscription {
  id                     String             @id @default(cuid())
  orgId                  String             @unique @map("org_id")
  plan                   Plan
  status                 SubscriptionStatus @default(ACTIVE)
  paymentProvider        String?            @map("payment_provider") // "culqi" | "stripe"
  externalSubscriptionId String?            @map("external_subscription_id")
  currentPeriodStart     DateTime           @map("current_period_start")
  currentPeriodEnd       DateTime           @map("current_period_end")
  cancelledAt            DateTime?          @map("cancelled_at")
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id])

  @@map("subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

// =============================================
// COMPLIANCE DIAGNOSTICS (FASE 2)
// =============================================

model ComplianceDiagnostic {
  id               String         @id @default(cuid())
  orgId            String         @map("org_id")
  type             DiagnosticType
  scoreGlobal      Int            @map("score_global") // 0-100
  scoreByArea      Json           @map("score_by_area") // { "contratos": 85, "sst": 60, ... }
  totalMultaRiesgo Decimal        @map("total_multa_riesgo") @db.Decimal(12, 2)
  questionsJson    Json           @map("questions_json") // preguntas y respuestas
  gapAnalysis      Json?          @map("gap_analysis") // brechas priorizadas
  actionPlan       Json?          @map("action_plan") // plan de accion generado
  completedAt      DateTime?      @map("completed_at")
  createdAt        DateTime       @default(now()) @map("created_at")

  organization Organization     @relation(fields: [orgId], references: [id])
  tasks        ComplianceTask[]

  @@index([orgId, createdAt])
  @@index([orgId, type]) // queries filtran por FULL|EXPRESS|SIMULATION
  @@map("compliance_diagnostics")
}

// Tareas accionables derivadas de brechas detectadas en un diagnostico o simulacro.
// Cada task representa una brecha priorizada que alguien debe resolver — con
// responsable opcional, plazo, gravedad y evidencia de subsanacion.
//
// F2.1 del plan maestro: "Boton 'Generar Plan de Accion' que crea tareas en el sistema".
model ComplianceTask {
  id            String               @id @default(cuid())
  orgId         String               @map("org_id")
  diagnosticId  String?              @map("diagnostic_id") // null si creada manualmente
  // Origen dentro del diagnostico (questionId del scorer o solicitudId del simulacro)
  sourceId      String?              @map("source_id")
  area          String // area_key: "sst", "contratos_registro", etc.
  priority      Int                  @default(0) // 1 = mas urgente
  title         String // accion corta: "Implementar IPERC firmado"
  description   String?              @db.Text // accion completa + contexto
  baseLegal     String?              @map("base_legal") // "Ley 29783, Art. 57"
  gravedad      InfracGravedad       @default(LEVE)
  multaEvitable Decimal?             @map("multa_evitable") @db.Decimal(12, 2)
  plazoSugerido String?              @map("plazo_sugerido") // "Inmediato (7 dias)"
  dueDate       DateTime?            @map("due_date")
  assignedTo    String?              @map("assigned_to") // userId del responsable
  status        ComplianceTaskStatus @default(PENDING)
  evidenceUrl   String?              @map("evidence_url")
  notes         String?              @db.Text
  completedAt   DateTime?            @map("completed_at")
  completedBy   String?              @map("completed_by") // userId
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  organization Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  diagnostic   ComplianceDiagnostic? @relation(fields: [diagnosticId], references: [id], onDelete: SetNull)

  @@index([orgId, status])
  @@index([orgId, dueDate])
  @@index([diagnosticId])
  @@map("compliance_tasks")
}

enum ComplianceTaskStatus {
  PENDING // Creada, sin asignar
  IN_PROGRESS // En proceso de subsanacion
  COMPLETED // Resuelta con evidencia
  DISMISSED // Descartada (ej. NA para este caso)
}

enum InfracGravedad {
  LEVE
  GRAVE
  MUY_GRAVE
}

enum DiagnosticType {
  FULL // 120 preguntas — diagnostico completo
  EXPRESS // 20 preguntas — rapido mensual
