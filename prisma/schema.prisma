  @@index([category])
  @@map("courses")
}

enum CourseCategory {
  SST // Seguridad y Salud en el Trabajo
  HOSTIGAMIENTO // Prevencion hostigamiento sexual
  DERECHOS_LABORALES // Derechos del trabajador
  CONTRATOS // Gestion de contratos por regimen
  PLANILLA // Planilla electronica y T-REGISTRO
  INSPECCIONES // Preparacion para inspecciones SUNAFIL
  IGUALDAD // Igualdad salarial y no discriminacion
  GENERAL // Temas generales compliance
}

model Lesson {
  id          String            @id @default(cuid())
  courseId    String            @map("course_id")
  title       String
  description String?
  contentType LessonContentType @map("content_type")
