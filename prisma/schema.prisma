// =============================================
// ATTENDANCE
// =============================================

model Attendance {
  id              String           @id @default(cuid())
  orgId           String           @map("org_id")
  workerId        String           @map("worker_id")
  clockIn         DateTime         @map("clock_in")
  clockOut        DateTime?        @map("clock_out")
  hoursWorked     Decimal?         @map("hours_worked") @db.Decimal(5, 2)
  status          AttendanceStatus @default(PRESENT)
  notes           String?
  // Horas extras detectadas automáticamente al hacer clock-out (Fase 1.3).
  // Una jornada que excede `Worker.jornadaSemanal / 5` se marca con isOvertime=true
  // y overtimeMinutes guarda los minutos extras (ej: 8.5h trabajadas con jornada
  // 8h → isOvertime=true, overtimeMinutes=30).
  isOvertime      Boolean          @default(false) @map("is_overtime")
  overtimeMinutes Int?             @map("overtime_minutes")
  // Anti-fraude (PRO+): geolocalización, device, selfie hash al check-in
  geoLat          Decimal?         @map("geo_lat") @db.Decimal(10, 7)
  geoLng          Decimal?         @map("geo_lng") @db.Decimal(10, 7)
  geoAccuracy     Decimal?         @map("geo_accuracy") @db.Decimal(8, 2)
  // Hash SHA-256 de la foto selfie tomada al marcar (no guardamos imagen
  // por privacidad/storage). El hash sirve como evidencia de presencia.
  // Sprint 6+ podrá comparar contra otros hashes para detectar fotos duplicadas.
  selfieHash      String?          @map("selfie_hash")
  createdAt       DateTime         @default(now()) @map("created_at")

  worker Worker @relation(fields: [workerId], references: [id])

  @@index([orgId, clockIn])
  @@index([workerId, clockIn])
  @@map("attendance")
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  ON_LEAVE
}

/// Geocercas persistentes (Fase 4 — Asistencia).
/// Antes vivían en Map<orgId, Geofence[]> en memoria, lo que se rompía en
/// Vercel multi-instance y al hacer rolling deploy. Ahora son persistentes.
model Geofence {
  id           String       @id @default(cuid())
  orgId        String       @map("org_id")
  name         String
  type         GeofenceType
  // CIRCLE: center + radius
  centerLat    Decimal?     @map("center_lat") @db.Decimal(10, 7)
  centerLng    Decimal?     @map("center_lng") @db.Decimal(10, 7)
  radiusMeters Int?         @map("radius_meters")
  // POLYGON: array de vertices [{lat,lng}, ...]
  vertices     Json?
  // Identificador opcional del local/obra/sede para reportes por ubicación
  locationId   String?      @map("location_id")
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@index([orgId, isActive])
  @@map("geofences")
}

enum GeofenceType {
  CIRCLE
  POLYGON
}

/// Log de intentos de fichado (Fase 4 — anti-fraude).
/// Persiste TODOS los intentos: exitosos y fallidos. Permite detectar patrones
/// sospechosos (muchos intentos fallidos por geofence_out, brute-force de PIN,
/// tokens reutilizados, etc.). TTL 30 días via cron de cleanup.
model AttendanceAttempt {
  id           String                  @id @default(cuid())
  orgId        String                  @map("org_id")
  workerId     String?                 @map("worker_id")
  result       AttendanceAttemptResult
  reason       String? // detalle del fallo si result != SUCCESS
  via          String? // "qr" | "pin" | "code" | "kiosko"
  geoLat       Decimal?                @map("geo_lat") @db.Decimal(10, 7)
  geoLng       Decimal?                @map("geo_lng") @db.Decimal(10, 7)
  geoAccuracy  Decimal?                @map("geo_accuracy") @db.Decimal(8, 2)
  ipAddress    String?                 @map("ip_address")
  userAgent    String?                 @map("user_agent") @db.Text
  metadataJson Json?                   @map("metadata_json")
  createdAt    DateTime                @default(now()) @map("created_at")

  @@index([orgId, createdAt])
  @@index([workerId, createdAt])
  @@index([result, createdAt])
  @@map("attendance_attempts")
}

enum AttendanceAttemptResult {
  SUCCESS
  TOKEN_EXPIRED
  TOKEN_INVALID
  ORG_MISMATCH
  GEOFENCE_OUT
  GEOLOCATION_REQUIRED
  PIN_WRONG
  RATE_LIMITED
  ALREADY_CLOCKED
  WORKER_NOT_FOUND
  ERROR
}

// =============================================
// PORTAL DEL TRABAJADOR
// Modelos para que cada empleado tenga acceso
// a su propia informacion (boletas, solicitudes,
// documentos personales).
// =============================================

model Payslip {
  id                 String        @id @default(cuid())
  orgId              String        @map("org_id")
  workerId           String        @map("worker_id")
  periodo            String // "2026-04" formato YYYY-MM
  fechaEmision       DateTime      @map("fecha_emision")
  sueldoBruto        Decimal       @map("sueldo_bruto") @db.Decimal(10, 2)
  asignacionFamiliar Decimal?      @map("asignacion_familiar") @db.Decimal(10, 2)
  horasExtras        Decimal?      @map("horas_extras") @db.Decimal(10, 2)
  bonificaciones     Decimal?      @db.Decimal(10, 2)
  totalIngresos      Decimal       @map("total_ingresos") @db.Decimal(10, 2)
  // Descuentos
  aporteAfpOnp       Decimal?      @map("aporte_afp_onp") @db.Decimal(10, 2)
  rentaQuintaCat     Decimal?      @map("renta_quinta_cat") @db.Decimal(10, 2)
  otrosDescuentos    Decimal?      @map("otros_descuentos") @db.Decimal(10, 2)
  totalDescuentos    Decimal       @map("total_descuentos") @db.Decimal(10, 2)
  // Neto
  netoPagar          Decimal       @map("neto_pagar") @db.Decimal(10, 2)
  // Aportes empleador (solo informativo)
  essalud            Decimal?      @db.Decimal(10, 2)
  // Archivo
  pdfUrl             String?       @map("pdf_url")
  detalleJson        Json?         @map("detalle_json") // breakdown completo
  // Status
  status             PayslipStatus @default(EMITIDA)
  acceptedAt         DateTime?     @map("accepted_at") // cuando el trabajador la confirma
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id])
  worker       Worker       @relation(fields: [workerId], references: [id])

  @@unique([workerId, periodo])
  @@index([orgId, periodo])
  @@index([orgId, status]) // portal worker + cron filtros
  @@index([workerId, periodo])
  @@map("payslips")
}

enum PayslipStatus {
  EMITIDA
  ENVIADA
  ACEPTADA
  OBSERVADA
  ANULADA
}

model WorkerRequest {
  id            String              @id @default(cuid())
  orgId         String              @map("org_id")
  workerId      String              @map("worker_id")
  type          WorkerRequestType
  status        WorkerRequestStatus @default(PENDIENTE)
  // Datos generales
  title         String
  description   String?
  // Datos especificos segun tipo
  startDate     DateTime?           @map("start_date")
  endDate       DateTime?           @map("end_date")
  daysRequested Int?                @map("days_requested")
  amount        Decimal?            @db.Decimal(10, 2)
  attachmentUrl String?             @map("attachment_url")
  // Revision
  reviewedById  String?             @map("reviewed_by_id")
  reviewedAt    DateTime?           @map("reviewed_at")
  reviewNotes   String?             @map("review_notes")
  // Audit
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id])
  worker       Worker       @relation(fields: [workerId], references: [id])
  reviewer     User?        @relation("RequestReviewer", fields: [reviewedById], references: [id])

  @@index([orgId, status])
  @@index([workerId, createdAt])
  @@map("worker_requests")
}

enum WorkerRequestType {
  VACACIONES
  PERMISO
  LICENCIA_MEDICA
  LICENCIA_MATERNIDAD
  LICENCIA_PATERNIDAD
  ADELANTO_SUELDO
  CTS_RETIRO_PARCIAL
  CONSTANCIA_TRABAJO
  CERTIFICADO_5TA
  ACTUALIZAR_DATOS
  OTRO
}

enum WorkerRequestStatus {
  PENDIENTE
  EN_REVISION
  APROBADA
  RECHAZADA
  CANCELADA
}

// =============================================
// DOCUMENTOS DE LA ORGANIZACION
// Documentos compartidos a nivel empresa que el
// trabajador puede consultar (RIT, politicas, MOF).
// =============================================

model OrgDocument {
  id                   String     @id @default(cuid())
  orgId                String     @map("org_id")
  type                 OrgDocType
  title                String
  description          String?
  fileUrl              String?    @map("file_url")
  fileSize             Int?       @map("file_size")
  mimeType             String?    @map("mime_type")
  version              Int        @default(1)
  isPublishedToWorkers Boolean    @default(false) @map("is_published_to_workers")
  publishedAt          DateTime?  @map("published_at")
  validUntil           DateTime?  @map("valid_until")
  uploadedById         String?    @map("uploaded_by_id")
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")

  // ─── Acknowledgment system (Idea 1 — auto-notify workers) ───────────────
  // Si true, cuando el doc se actualiza (version bump) → notifica a todos
  // los workers activos y exige acuse de recibo con valor legal SUNAFIL.
  acknowledgmentRequired     Boolean   @default(false) @map("ack_required")
  // Días que el worker tiene para firmar antes de escalar al admin (null = sin deadline)
  acknowledgmentDeadlineDays Int?      @map("ack_deadline_days")
  // Filtro JSON para limitar quién debe firmar (null = todos los workers activos)
  // Ej: { "regimen": ["GENERAL", "MYPE_PEQUENA"] } excluye CAS / modalidad formativa
  scopeFilter                Json?     @map("scope_filter")
  // Última vez que se envió notificación batch — para throttling (max 1/semana)
  lastNotifiedAt             DateTime? @map("last_notified_at")

  organization    Organization             @relation(fields: [orgId], references: [id])
  acknowledgments DocumentAcknowledgment[]

  @@index([orgId, type])
  @@index([orgId, isPublishedToWorkers])
  @@map("org_documents")
}

/// Plantillas propias de la empresa. Reemplaza el uso legacy de
/// OrgDocument.description como storage estructurado de templates.
model OrgTemplate {
  id           String   @id @default(cuid())
  orgId        String   @map("org_id")
  title        String
  documentType String   @map("document_type")
  contractType String?  @map("contract_type")
  content      String   @db.Text
  placeholders Json
  mappings     Json
  notes        String?  @db.Text
  usageCount   Int      @default(0) @map("usage_count")
  version      Int      @default(1)
  active       Boolean  @default(true)
  createdById  String?  @map("created_by_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, active])
  @@index([orgId, documentType])
  @@map("org_templates")
}

/**
 * DocumentAcknowledgment — acuse de recibo del trabajador para una versión
 * específica de un OrgDocument (RIT, Política SST, Política Hostigamiento, etc.).
 * Diseñado para defensa legal SUNAFIL bajo Ley 27269 (firma electrónica):
 * - documentVersion garantiza trazabilidad exacta de qué texto firmó
 * - signatureMethod soporta SIMPLE | BIOMETRIC | OTP_EMAIL
 * - signatureProof guarda metadata específica del método (credentialId, etc.)
 * - ip + userAgent + scrolledToEnd + readingTimeMs = evidencia de lectura genuina
 * Uno por (worker, doc, version) — si admin actualiza la versión, worker
 * debe firmar de nuevo.
 */
model DocumentAcknowledgment {
  id              String   @id @default(cuid())
  orgId           String   @map("org_id")
  workerId        String   @map("worker_id")
  documentId      String   @map("document_id")
  documentVersion Int      @map("document_version")
  acknowledgedAt  DateTime @default(now()) @map("acknowledged_at")

  // Métodos de firma (orden de fortaleza legal: SIMPLE < OTP_EMAIL < BIOMETRIC)
  signatureMethod String @map("signature_method")
  signatureProof  Json?  @map("signature_proof")

  // Evidencia técnica de lectura — para defensa en juicio
  ip            String?
  userAgent     String? @map("user_agent")
  scrolledToEnd Boolean @default(false) @map("scrolled_to_end")
  readingTimeMs Int?    @map("reading_time_ms")

  worker       Worker       @relation(fields: [workerId], references: [id])
  document     OrgDocument  @relation(fields: [documentId], references: [id])
  organization Organization @relation(fields: [orgId], references: [id])

  @@unique([workerId, documentId, documentVersion])
  @@index([orgId, documentId])
  @@index([workerId, acknowledgedAt])
  @@map("document_acknowledgments")
}

enum OrgDocType {
  RIT // Reglamento Interno de Trabajo
  REGLAMENTO_SST // Reglamento de Seguridad y Salud
  POLITICA_HOSTIGAMIENTO // Politica prevencion hostigamiento sexual
  POLITICA_IGUALDAD // Politica igualdad salarial
  CODIGO_ETICA // Codigo de etica
  MOF // Manual de Organizacion y Funciones
  ROF // Reglamento de Organizacion y Funciones
  PLAN_SST // Plan anual de seguridad
  PROTOCOLO_DENUNCIAS // Protocolo canal de denuncias
  CONVENIO_COLECTIVO // Convenio colectivo vigente
  COMUNICADO // Comunicado general
  OTRO
}

// =============================================
// SERVICE PROVIDERS (4ta categoria / Recibos por Honorarios)
// =============================================
// Prestadores de servicios independientes que emiten RH.
// Regidos por el Codigo Civil (Art. 1764 — Locacion de Servicios), NO por el D.Leg. 728.
// NO tienen CTS, gratificaciones, vacaciones ni asignacion familiar.
// Retencion 8% IR 4ta categoria si > 1/7 UIT mensual y sin constancia de suspension.
// Riesgo principal: DESNATURALIZACION (reclasificacion a 5ta por SUNAFIL si hay subordinacion).

model ServiceProvider {
  id                     String                @id @default(cuid())
  orgId                  String                @map("org_id")
  // Identificacion
  documentType           String                @default("DNI") @map("document_type") // DNI, CE, RUC, PASAPORTE
  documentNumber         String                @map("document_number")
  ruc                    String? // RUC del prestador (obligatorio para emitir RH electronico)
  firstName              String                @map("first_name")
  lastName               String                @map("last_name")
  email                  String?
  phone                  String?
  address                String?
  profession             String? // Profesion/especialidad (ej: Contador, Ingeniero, Diseñador)
  // Servicio contratado
  servicioDescripcion    String                @map("servicio_descripcion") // Descripcion breve del servicio
  area                   String? // Area de la empresa donde presta servicio
  startDate              DateTime              @map("start_date") // Inicio del servicio
  endDate                DateTime?             @map("end_date") // Fin previsto (si hay)
  monthlyAmount          Decimal               @map("monthly_amount") @db.Decimal(10, 2) // Monto mensual acordado
  currency               String                @default("PEN")
  paymentFrequency       String                @default("MONTHLY") @map("payment_frequency") // MONTHLY, BIWEEKLY, PROJECT, HOURLY
  // Retencion de 4ta categoria
  hasSuspensionRetencion Boolean               @default(false) @map("has_suspension_retencion") // Constancia vigente de SUNAT
  suspensionExpiryDate   DateTime?             @map("suspension_expiry_date") // Vence cada 31 de diciembre
  // Analisis de riesgo de desnaturalizacion (indicadores laborales)
  hasFixedSchedule       Boolean               @default(false) @map("has_fixed_schedule") // Horario fijo impuesto
  hasExclusivity         Boolean               @default(false) @map("has_exclusivity") // Exclusividad con la empresa
  worksOnPremises        Boolean               @default(false) @map("works_on_premises") // Trabaja dentro de las instalaciones
  usesCompanyTools       Boolean               @default(false) @map("uses_company_tools") // Usa equipos/herramientas de la empresa
  reportsToSupervisor    Boolean               @default(false) @map("reports_to_supervisor") // Tiene jefe directo
  receivesOrders         Boolean               @default(false) @map("receives_orders") // Recibe ordenes directas
  desnaturalizacionRisk  Int                   @default(0) @map("desnaturalizacion_risk") // 0-100 calculado desde los flags
  // Documentacion
  contractFileUrl        String?               @map("contract_file_url") // PDF del contrato de locacion de servicios
  // Estado
  status                 ServiceProviderStatus @default(ACTIVE)
  notes                  String?
  createdAt              DateTime              @default(now()) @map("created_at")
  updatedAt              DateTime              @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id])
  rhInvoices   RhInvoice[]

  @@unique([orgId, documentNumber])
  @@index([orgId, status])
  @@map("service_providers")
}

enum ServiceProviderStatus {
  ACTIVE
  INACTIVE
  TERMINATED
  AT_RISK // Riesgo alto de desnaturalizacion
}

model RhInvoice {
  id            String    @id @default(cuid())
  orgId         String    @map("org_id")
  providerId    String    @map("provider_id")
  invoiceNumber String    @map("invoice_number") // E001-123 o similar
  issueDate     DateTime  @map("issue_date")
  periodo       String // YYYY-MM — mes de servicio prestado
  grossAmount   Decimal   @map("gross_amount") @db.Decimal(10, 2)
  retention     Decimal   @default(0) @db.Decimal(10, 2) // 8% IR si aplica
  netAmount     Decimal   @map("net_amount") @db.Decimal(10, 2)
  hasRetention  Boolean   @default(false) @map("has_retention")
  status        String    @default("PENDING") // PENDING, PAID, CANCELLED
  paidAt        DateTime? @map("paid_at")
  fileUrl       String?   @map("file_url") // PDF del recibo electronico
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  organization Organization    @relation(fields: [orgId], references: [id])
  provider     ServiceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([orgId, periodo])
  @@index([providerId, issueDate])
  @@map("rh_invoices")
}

