model Complaint {
  id                 String             @id @default(cuid())
  orgId              String             @map("org_id")
  code               String             @unique // DENUNCIA-2026-001
  type               ComplaintType
  isAnonymous        Boolean            @default(true) @map("is_anonymous")
  reporterName       String?            @map("reporter_name")
  reporterEmail      String?            @map("reporter_email")
  reporterPhone      String?            @map("reporter_phone")
  accusedName        String?            @map("accused_name")
  accusedPosition    String?            @map("accused_position")
  description        String
  evidenceUrls       String[]           @map("evidence_urls")
  status             ComplaintStatus    @default(RECEIVED)
  assignedTo         String?            @map("assigned_to")
  resolution         String?
  protectionMeasures Json?              @map("protection_measures")
  receivedAt         DateTime           @default(now()) @map("received_at")
  resolvedAt         DateTime?          @map("resolved_at")
  // Triaje IA (Fase γ) — la IA clasifica severidad/urgencia al recibir la
  // denuncia y sugiere medidas de protección. Ver `src/lib/ai/complaint-triage.ts`.
  // `severityAi` y `urgencyAi` se promueven a columnas para índice + WHERE.
  // El payload rico (summary, redFlags, medidas sugeridas, model) vive en triageJson.
  severityAi         ComplaintSeverity? @map("severity_ai")
  urgencyAi          ComplaintUrgency?  @map("urgency_ai")
  triageJson         Json?              @map("triage_json")
  triagedAt          DateTime?          @map("triaged_at")
  triageVersion      Int                @default(1) @map("triage_version")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  organization Organization        @relation(fields: [orgId], references: [id])
  timeline     ComplaintTimeline[]

  @@index([orgId, status])
  @@index([orgId, severityAi])
  @@map("complaints")
}

enum ComplaintType {
  HOSTIGAMIENTO_SEXUAL
  DISCRIMINACION
  ACOSO_LABORAL
  OTRO
}

enum ComplaintSeverity {
  BAJA
  MEDIA
  ALTA
  CRITICA
}

enum ComplaintUrgency {
  BAJA
  MEDIA
  ALTA
  INMEDIATA
}

enum ComplaintStatus {
  RECEIVED
  UNDER_REVIEW
  INVESTIGATING
  PROTECTION_APPLIED
  RESOLVED
  DISMISSED
}

model ComplaintTimeline {
  id          String   @id @default(cuid())
