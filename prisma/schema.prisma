// =============================================
// PORTAL DEL TRABAJADOR
// Modelos para que cada empleado tenga acceso
// a su propia informacion (boletas, solicitudes,
// documentos personales).
// =============================================

model Payslip {
  id                 String        @id @default(cuid())
  orgId              String        @map("org_id")
  workerId           String        @map("worker_id")
  periodo            String // "2026-04" formato YYYY-MM
  fechaEmision       DateTime      @map("fecha_emision")
  sueldoBruto        Decimal       @map("sueldo_bruto") @db.Decimal(10, 2)
  asignacionFamiliar Decimal?      @map("asignacion_familiar") @db.Decimal(10, 2)
  horasExtras        Decimal?      @map("horas_extras") @db.Decimal(10, 2)
  bonificaciones     Decimal?      @db.Decimal(10, 2)
  totalIngresos      Decimal       @map("total_ingresos") @db.Decimal(10, 2)
  // Descuentos
  aporteAfpOnp       Decimal?      @map("aporte_afp_onp") @db.Decimal(10, 2)
  rentaQuintaCat     Decimal?      @map("renta_quinta_cat") @db.Decimal(10, 2)
  otrosDescuentos    Decimal?      @map("otros_descuentos") @db.Decimal(10, 2)
  totalDescuentos    Decimal       @map("total_descuentos") @db.Decimal(10, 2)
  // Neto
  netoPagar          Decimal       @map("neto_pagar") @db.Decimal(10, 2)
  // Aportes empleador (solo informativo)
  essalud            Decimal?      @db.Decimal(10, 2)
  // Archivo
  pdfUrl             String?       @map("pdf_url")
  detalleJson        Json?         @map("detalle_json") // breakdown completo
  // Status
  status             PayslipStatus @default(EMITIDA)
  acceptedAt         DateTime?     @map("accepted_at") // cuando el trabajador la confirma
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id])
  worker       Worker       @relation(fields: [workerId], references: [id])

  @@unique([workerId, periodo])
  @@index([orgId, periodo])
  @@index([orgId, status]) // portal worker + cron filtros
  @@index([workerId, periodo])
  @@map("payslips")
}

enum PayslipStatus {
  EMITIDA
  ENVIADA
  ACEPTADA
  OBSERVADA
  ANULADA
}

