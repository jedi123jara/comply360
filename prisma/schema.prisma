// =============================================
// WORKFLOWS (FASE 4 — automatización compliance)
// =============================================
// Persistencia del motor definido en src/lib/workflows/engine.ts.
// Los pasos viven en `stepsJson` como JSON (shape: WorkflowStep[]) para
// evitar una explosión de tablas. Los templates prefabricados se usan
// para la creación; el editor visual libre queda fuera del MVP.

model Workflow {
  id          String   @id @default(cuid())
  orgId       String   @map("org_id")
  name        String
  description String?
  version     Int      @default(1)
  active      Boolean  @default(true)
  triggerId   String   @map("trigger_id") // ID del trigger (ver triggers.ts)
  stepsJson   Json     @map("steps_json") // WorkflowStep[] serializado
  metadata    Json?
  createdBy   String?  @map("created_by") // email del creador
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  runs WorkflowRun[]

  @@index([orgId, active])
  @@index([orgId, createdAt])
  @@map("workflows")
}

// =============================================
// SCHEDULED REPORTS (FASE δ — envío automático)
// =============================================
// Permite al admin configurar "enviame el Reporte Ejecutivo de Compliance
// cada primer lunes del mes a rrhh@empresa.com". Un cron endpoint corre
// cada 5 min, lista los activos, y para los que matchean la expresión cron
// actual (timezone Lima via matchesCron refactorizado), genera PDF/XLSX y
// envía email.
//
// Decisión: sin `nextRunAt` — ambiguo con TZ y requiere parser cron completo.
// La UI calcula el próximo disparo client-side con `cron-parser`.

model ScheduledReport {
  id             String   @id @default(cuid())
  orgId          String   @map("org_id")
  reportType     String   @map("report_type") // 'compliance-ejecutivo' | 'sst-anual' | 'workers' | ...
  cronExpression String   @map("cron_expression") // ej "0 8 1 * *"
  recipients     String[] // emails destinatarios
  format         String // 'PDF' | 'XLSX' | 'BOTH'
  params         Json? // filtros por tipo (year, department, regime)
  active         Boolean  @default(true)
  lastRunAt      DateTime? @map("last_run_at")
  lastRunStatus  String?   @map("last_run_status") // 'SUCCESS' | 'FAILED'
  lastRunError   String?   @map("last_run_error") @db.Text
  createdBy      String?  @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([orgId, active])
  @@map("scheduled_reports")
}

model WorkflowRun {
  id               String    @id @default(cuid())
  workflowId       String    @map("workflow_id")
  orgId            String    @map("org_id")
  status           String // 'PENDING' | 'RUNNING' | 'COMPLETED' | 'FAILED' | 'WAITING_APPROVAL' | 'CANCELLED'
  triggerData      Json      @map("trigger_data")
  stepResultsJson  Json      @map("step_results_json") // StepResult[]
  context          Json?
  currentStepIndex Int       @default(0) @map("current_step_index")
  startedAt        DateTime  @default(now()) @map("started_at")
  completedAt      DateTime? @map("completed_at")
  error            String?
  triggeredBy      String?   @map("triggered_by") // email o 'cron' o 'event:...'
  /**
   * Hash sha256 determinístico para deduplicar runs disparados por el event
   * bus cuando hay retries HTTP concurrentes. Null para runs manuales.
   * Ver `src/lib/events/handlers/workflow-handler.ts` → `computeIdempotencyKey`.
   */
  idempotencyKey   String?   @unique @map("idempotency_key")

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId, startedAt])
  @@index([orgId, startedAt])
  @@index([orgId, status])
  @@map("workflow_runs")
}

/**
 * Suscripciones de webhooks salientes (API pública v1).
 *
 * Cliente B2B configura un endpoint propio + lista de eventos a recibir.
 * Cuando el event bus interno emite un `DomainEvent`, el handler de webhook
 * dispatch busca subs activas matching y crea filas `WebhookDelivery` que
 * el cron `webhook-retry` procesa con HMAC + backoff exponencial.
 *
 * Patrón de seguridad:
 *   - HMAC-SHA256 sobre el body, header `X-Comply360-Signature`
 *   - Replay protection con `X-Comply360-Timestamp` (ventana 5min)
 */
model WebhookSubscription {
  id              String   @id @default(cuid())
  orgId           String   @map("org_id")
  url             String
  events          String[] @default([])
  /**
   * Secret aleatorio (32 bytes hex). Comply360 lo guarda en claro porque
   * es shared secret HMAC, NO credencial de usuario. Se exhibe UNA vez al
   * crear la sub.
   */
  secret          String
  description     String?
  active          Boolean  @default(true)
  lastDeliveryAt  DateTime? @map("last_delivery_at")
  lastDeliveryStatus String? @map("last_delivery_status")
  consecutiveFailures Int   @default(0) @map("consecutive_failures")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  createdBy       String?  @map("created_by")

  deliveries      WebhookDelivery[]

  @@index([orgId, active])
  @@map("webhook_subscriptions")
}

/**
 * Cada intento de entrega de un webhook saliente.
 * El cron `webhook-retry` procesa rows en estado PENDING/FAILED con backoff
 * exponencial (1m, 5m, 30m, 2h, 12h) hasta 5 intentos. Tras 5 fallos
 * consecutivos en una misma sub, la sub queda `active=false`.
 */
model WebhookDelivery {
  id              String   @id @default(cuid())
  subscriptionId  String   @map("subscription_id")
  orgId           String   @map("org_id")
  eventName       String   @map("event_name")
  eventId         String   @map("event_id")
  payload         Json
  status          String   @default("PENDING")
  attempts        Int      @default(0)
  lastAttemptAt   DateTime? @map("last_attempt_at")
  nextRetryAt     DateTime? @map("next_retry_at")
  responseStatus  Int?     @map("response_status")
  responseBody    String?  @map("response_body")
  error           String?
  createdAt       DateTime @default(now()) @map("created_at")
  completedAt     DateTime? @map("completed_at")

  subscription    WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([status, nextRetryAt])
  @@index([subscriptionId, createdAt])
  @@index([orgId, createdAt])
  @@map("webhook_deliveries")
}

/**
 * Sello "Compliance-Ready" — distintivo público que la empresa exhibe en
 * su web propia para acreditar el cumplimiento sostenido en el tiempo.
 *
 * Reglas de emisión (cron mensual):
 *   - score actual ≥ 80
 *   - score promedio últimos 90 días ≥ 80
 *
 * Verificación pública en `/verify/[slug]` — devuelve org info, score
 * histórico simple, y `validUntil`. SEO-friendly + lock-in real porque la
 * empresa publica el badge en su web (link de vuelta a Comply360).
 *
 * Tiers visuales:
 *   - BRONZE: score 80-89
 *   - SILVER: score 90-94
 *   - GOLD:   score ≥95
 */
model OrgComplianceSeal {
  id            String   @id @default(cuid())
  orgId         String   @map("org_id")
  slug          String   @unique
  scoreAtIssue  Int      @map("score_at_issue")
  scoreAvg90d   Int      @map("score_avg_90d")
  tier          String   @default("BRONZE")
  issuedAt      DateTime @default(now()) @map("issued_at")
  validUntil    DateTime @map("valid_until")
  revokedAt     DateTime? @map("revoked_at")
  revokedReason String?   @map("revoked_reason")

  @@index([orgId, issuedAt])
  @@index([validUntil])
  @@map("org_compliance_seals")
}

/**
 * Bitácora idempotente de ejecuciones de crons.
 *
 * Cada cron registra su corrida acá con (cronName, bucket). El `bucket` es
 * un identificador determinístico del intervalo en el que cae la corrida
 * (por ejemplo el minuto en formato `YYYYMMDDHHmm`). El unique constraint
 * `[cronName, bucket]` previene que dos invocaciones en el mismo bucket
 * ejecuten el handler — usual cuando Vercel reintenta o cuando alguien
 * dispara manualmente con `curl` mientras el cron está corriendo.
 *
 * Uso desde un cron:
 *   const claim = await claimCronRun('morning-briefing')
 *   if (!claim.acquired) return Response.json({ duplicate: true })
 *   try { ...trabajo real... }
 *   await completeCronRun(claim.runId, { ok: true, processed: 42 })
 */
model CronRun {
  id          String    @id @default(cuid())
  cronName    String    @map("cron_name")
  /**
   * Bucket determinístico del intervalo. Default = `YYYYMMDDHHmm`.
   * Permite idempotencia natural por minuto sin requerir clock alineado.
   */
  bucket      String
  status      String    @default("RUNNING") // RUNNING | COMPLETED | FAILED
  result      Json?
  error       String?
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  @@unique([cronName, bucket])
  @@index([cronName, startedAt])
  @@map("cron_runs")
}

/**
 * Telemetría de uso de IA — un registro por llamada al LLM.
 *
 * Permite responder preguntas críticas sin pelear con logs:
 *   - ¿Cuánto USD gasté esta semana en gpt-4o-mini para contract-review?
 *   - ¿Qué org consume el 80% del budget?
 *   - ¿Tengo orgs FREE quemando tokens (= bug)?
 *   - ¿Qué feature tiene latencia p95 mala?
 *
 * Sin esto, escalar IA es a ciegas: cada feature nueva genera costo opaco.
 *
 * Persistencia es **fire-and-forget** desde el helper — si la creación
 * falla, la llamada al LLM ya tuvo éxito y no debemos romper el flujo del
 * usuario. Se logea el error a console.
 */
model AiUsage {
  id               String   @id @default(cuid())
  orgId            String?  @map("org_id") // null para llamadas de cron/health
  userId           String?  @map("user_id")
  feature          String // 'chat' | 'contract-review' | 'document-verify' | 'action-plan' | 'agents:<name>' | 'unknown'
  provider         String // 'openai' | 'groq' | 'deepseek' | 'ollama' | 'simulated'
  model            String
  promptTokens     Int      @default(0) @map("prompt_tokens")
  completionTokens Int      @default(0) @map("completion_tokens")
  totalTokens      Int      @default(0) @map("total_tokens")
  /**
   * Costo estimado en USD calculado con la pricing table local.
   * NO refleja ningún descuento de volumen ni precio enterprise — sirve
   * como guía para alertas y presupuesto, no como factura.
   */
  costUsd          Decimal  @default(0) @map("cost_usd") @db.Decimal(12, 6)
  latencyMs        Int?     @map("latency_ms")
  success          Boolean  @default(true)
  errorMessage     String?  @map("error_message")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([orgId, createdAt])
  @@index([orgId, feature, createdAt])
  @@index([feature, createdAt])
  @@map("ai_usage")
}

/**
 * Credenciales WebAuthn registradas por usuarios para firma biométrica.
 *
 * Cada vez que un trabajador registra su huella / Face ID / Windows Hello en
 * el portal, almacenamos la `publicKey` que el authenticator nos entrega. En
 * cada firma posterior validamos la `assertion` contra esta clave pública
 * usando `@simplewebauthn/server` (`verifyAuthenticationResponse`).
 *
 * Sin esto, la firma biométrica solo verifica el challenge JWT — no prueba
 * que es ESE dispositivo específico el que firma. Con esto, una firma falsa
 * desde un device distinto se rechaza criptográficamente, alcanzando la
 * "firma electrónica fuerte" de la Ley 27269.
 *
 * Campos:
 *   - credentialID: bytes del credential id devuelto por el authenticator.
 *   - publicKey:    bytes de la clave pública (formato CBOR, COSE_Key).
 *   - counter:      anti-cloning. Incrementa cada uso. Si baja → rechazo.
 *   - transports:   ['internal','hybrid','usb', ...] reportado por el browser.
 *   - aaguid:       identifier del modelo de authenticator (16 bytes hex).
 *   - deviceType:   'singleDevice' | 'multiDevice' (passkeys sincronizables).
 *   - backedUp:     true si la passkey está en iCloud/Google Password Manager.
 *   - legacy:       credentials registrados antes de Sprint 1 con engine
 *                   casero. Se aceptan en modo no estricto pero el usuario
 *                   debe re-enrollar para obtener firma fuerte.
 */
model WebAuthnCredential {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  credentialID Bytes    @map("credential_id")
  publicKey    Bytes    @map("public_key")
  counter      BigInt   @default(0)
  transports   String[] @default([])
  aaguid       String?
  deviceType   String?  @map("device_type")
  backedUp     Boolean  @default(false) @map("backed_up")
  nickname     String? // ej. "iPhone 15 — huella"
  legacy       Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")
  lastUsedAt   DateTime? @map("last_used_at")

  @@unique([userId, credentialID])
  @@index([userId])
  @@map("webauthn_credentials")
}

/**
 * Idempotencia de webhooks entrantes.
 *
 * Culqi (y otros providers en el futuro) reenvían eventos cuando el receptor
 * tarda en responder o cae. Sin dedupe, `charge.success` reenviado puede
 * extender el `currentPeriodEnd` de la subscription un mes extra por cada
 * retry, regalando plan al cliente.
 *
 * Flow:
 *   1. Webhook entra → `upsert { provider_externalId }` con `processedAt: null`.
 *   2. Si `processedAt != null` → 200 OK + `{ duplicated: true }` sin reprocesar.
 *   3. Si es nuevo → procesar handler → marcar `processedAt = now()` + `status`.
 *
 * Ver `src/app/api/payments/webhook/route.ts`.
 */
model WebhookEvent {
  id           String    @id @default(cuid())
  provider     String // 'culqi' | 'clerk' | 'resend' | ...
  externalId   String    @map("external_id") // chargeId, eventId del provider
  eventType    String?   @map("event_type") // 'charge.success', etc.
  payload      Json
  status       String    @default("RECEIVED") // RECEIVED | PROCESSED | FAILED | DUPLICATED
  error        String?
  receivedAt   DateTime  @default(now()) @map("received_at")
  processedAt  DateTime? @map("processed_at")

  @@unique([provider, externalId])
  @@index([provider, status])
  @@index([receivedAt])
  @@map("webhook_events")
}
