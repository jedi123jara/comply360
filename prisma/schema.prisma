  updatedAt   DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  worker       Worker       @relation(fields: [workerId], references: [id], onDelete: Cascade)
  position     OrgPosition  @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@index([orgId, workerId, endedAt])
  @@index([orgId, positionId, endedAt])
  @@map("org_assignments")
}

model OrgComplianceRole {
  id        String             @id @default(cuid())
  orgId     String             @map("org_id")
  workerId  String             @map("worker_id")
  roleType  ComplianceRoleType @map("role_type")
  unitId    String?            @map("unit_id")
  startsAt  DateTime           @default(now()) @map("starts_at")
  endsAt    DateTime?          @map("ends_at")
  electedAt DateTime?          @map("elected_at")
  actaUrl   String?            @map("acta_url")
  baseLegal String?            @map("base_legal")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  worker       Worker       @relation(fields: [workerId], references: [id], onDelete: Cascade)
  unit         OrgUnit?     @relation(fields: [unitId], references: [id], onDelete: SetNull)

  @@index([orgId, roleType, endsAt])
  @@index([orgId, workerId])
  @@map("org_compliance_roles")
}

model OrgChartSnapshot {
  id          String   @id @default(cuid())
  orgId       String   @map("org_id")
  label       String
  reason      String?
  takenById   String?  @map("taken_by_id")
  payload     Json
  workerCount Int      @default(0) @map("worker_count")
  unitCount   Int      @default(0) @map("unit_count")
  depthMax    Int      @default(0) @map("depth_max")
  hash        String
  isAuto      Boolean  @default(false) @map("is_auto")
  createdAt   DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, hash])
  @@index([orgId, createdAt])
  @@map("org_chart_snapshots")
}

model OrgChartDraft {
  id             String    @id @default(cuid())
  orgId          String    @map("org_id")
  name           String
  baseSnapshotId String?   @map("base_snapshot_id")
  payload        Json
  diffSummary    Json?     @map("diff_summary")
  impactReport   Json?     @map("impact_report")
  createdById    String    @map("created_by_id")
  status         String    @default("DRAFT") // DRAFT | REVIEWING | APPLIED | DISCARDED
  appliedAt      DateTime? @map("applied_at")
  appliedById    String?   @map("applied_by_id")
