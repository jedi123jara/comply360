// =============================================
// NPS — Net Promoter Score in-product feedback
// =============================================
// Modelo simple: una respuesta NPS por user. Score 0-10 (0=detractor, 9-10=promoter).
// El comentario es opcional. Se pregunta una sola vez por user (UI bloquea repetición
// con localStorage + check server-side via existing record).

model NpsFeedback {
  id        String   @id @default(cuid())
  orgId     String   @map("org_id")
  userId    String   @map("user_id")
  score     Int // 0-10
  comment   String?  @db.Text
  source    String? // "dashboard", "post-onboarding", etc.
