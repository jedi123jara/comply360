  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  organization    Organization         @relation(fields: [orgId], references: [id])
  createdBy       User                 @relation("CreatedBy", fields: [createdById], references: [id])
  template        ContractTemplate?    @relation(fields: [templateId], references: [id])
  workerContracts WorkerContract[]
  validations     ContractValidation[]
  versions        ContractVersion[]

  @@index([orgId, status])
  @@index([orgId, type])
  @@index([orgId, provenance])
  @@index([orgId, isFallback])
  @@index([orgId, expiresAt]) // calendar queries por fecha en ventana
  @@index([expiresAt])
  @@map("contracts")
}

enum ContractStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  SIGNED
  EXPIRED
  ARCHIVED
}

// =============================================
// CONTRACT VALIDATION ENGINE (Generador de Contratos — Chunk 1)
// Reglas declarativas (ContractValidationRule) + resultados por contrato
// (ContractValidation). Ver docs/specs/contract-generator-spec.md §11.
// Las reglas viven como DATOS, no como código → futuras casaciones se
// despliegan como migraciones de seed sin redeploy.
// =============================================

enum ValidationSeverity {
  BLOCKER // Impide emitir / firmar el contrato
  WARNING // Permite emitir si hay acknowledgement explícito
  INFO // Sugerencia de mejora
}

model ContractValidationRule {
  id          String             @id @default(cuid())
  code        String             @unique // "FORMAL-001", "MODAL-001", etc.
  category    String // "FORMAL" | "MODAL" | "PLAZO" | "SUPLENCIA" | "GESTANTE" | "RMV" | "TPARCIAL" | "EXTRANJ" | "PRUEBA" | "DATOS"
  severity    ValidationSeverity
  title       String
  description String             @db.Text
  legalBasis  String             @db.Text // "Art. 72 LPCL — Cas. Lab. 13734-2017-Lima"
  ruleSpec    Json               @map("rule_spec") // declarative spec — ver lib/contracts/validation/types.ts
  appliesTo   Json?              @map("applies_to") // { contractTypes?: ContractType[], regimes?: RegimenLaboral[] } — null = aplica siempre
  active      Boolean            @default(true)
  version     String             @default("1.0.0") // semver: refleja cambios al ruleSpec
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  validations ContractValidation[]

  @@index([category, active])
  @@map("contract_validation_rules")
}

model ContractValidation {
  id                 String             @id @default(cuid())
  orgId              String             @map("org_id") // denormalizado: filtros por tenant
  contractId         String             @map("contract_id")
  ruleId             String             @map("rule_id")
  ruleCode           String             @map("rule_code") // denormalizado para queries rápidas
  ruleVersion        String             @map("rule_version") // versión del ruleSpec aplicado
  passed             Boolean
  severity           ValidationSeverity
  message            String             @db.Text
  evidence           Json? // datos del contexto que dispararon (o no) la regla
  acknowledged       Boolean            @default(false)
  acknowledgedBy     String?            @map("acknowledged_by")
  acknowledgedAt     DateTime?          @map("acknowledged_at")
  acknowledgedReason String?            @map("acknowledged_reason") @db.Text
  createdAt          DateTime           @default(now()) @map("created_at")

  rule     ContractValidationRule @relation(fields: [ruleId], references: [id])
  contract Contract               @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([orgId, contractId])
  @@index([contractId, passed])
  @@index([ruleCode])
  @@map("contract_validations")
}

// =============================================
// CRYPTOGRAPHIC ANCHORING (Generador de Contratos — Chunk 8)
// Anclaje diario del set de versionHash de cada tenant en un Merkle root,
// con timestamping externo opcional (RFC 3161 vía TSA INDECOPI y/o
// OpenTimestamps sobre Bitcoin). Cada `ContractVersion` queda enlazado
// a su MerkleAnchor del día → posible exhibir prueba inmutable ante peritos.
// Ver docs/specs/contract-generator-spec.md §10.
// =============================================

model MerkleAnchor {
  id         String   @id @default(cuid())
  orgId      String   @map("org_id")
  /// Día calendario UTC (YYYY-MM-DD) — clave junto con orgId.
  anchorDate DateTime @map("anchor_date") @db.Date
  /// Total de hojas en el árbol — versions del día para esa org.
  leafCount  Int      @map("leaf_count")
  /// Hojas: [{ versionId, versionHash, leafIndex }]. Permite reconstruir.
  leaves     Json
  /// Raíz del árbol: SHA-256 hex 64 chars.
  merkleRoot String   @map("merkle_root")

  // ── Anclaje externo (opcional) ─────────────────────────────────────
  /// RFC 3161 TimeStampToken (binary). Serialización CMS según RFC 3161.
  rfc3161Token Bytes?    @map("rfc3161_token")
  /// Authority que emitió el token (URL TSA o nombre acreditado).
  rfc3161Tsa   String?   @map("rfc3161_tsa")
  rfc3161At    DateTime? @map("rfc3161_at")

  /// OpenTimestamps proof (binary, formato .ots).
  otsProof           Bytes?    @map("ots_proof")
  otsCalendar        String?   @map("ots_calendar") // URL del calendar server
  otsAt              DateTime? @map("ots_at")
  /// Bitcoin block height cuando OTS confirma — null hasta upgrade.
  bitcoinBlockHeight Int?      @map("bitcoin_block_height")

  /// Estado del anclaje: PENDING | RFC3161_OK | OTS_OK | FULL_OK | FAILED
  status    String   @default("PENDING")
  errors    Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  versions ContractVersion[]

  @@unique([orgId, anchorDate])
  @@index([anchorDate])
  @@index([orgId, status])
  @@map("merkle_anchors")
}

// =============================================
// BULK CONTRACT JOBS (Generador de Contratos — Chunk 7)
// Audit trail de cada generación masiva: qué archivo subió el usuario,
// cuántas filas, cuáles dieron error, hash del ZIP resultante. El proceso
// real corre síncrono en el endpoint /generate (sin Redis); el modelo
// existe para trazabilidad y para futuras corridas con BullMQ.
// =============================================

enum BulkJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

model BulkContractJob {
  id             String        @id @default(cuid())
  orgId          String        @map("org_id")
  createdById    String        @map("created_by_id")
  status         BulkJobStatus @default(QUEUED)
  /// Tipo de contrato a generar (ContractType enum)
  contractType   String        @map("contract_type")
  /// Plantilla / lógica usada — opcional
  templateId     String?       @map("template_id")
  /// Nombre del archivo origen
  sourceFileName String?       @map("source_file_name")
  totalRows      Int           @map("total_rows")
  succeededRows  Int           @default(0) @map("succeeded_rows")
  failedRows     Int           @default(0) @map("failed_rows")
  /// Errores por fila: [{ row: 5, message: "DNI inválido" }]
  errors         Json?
  /// SHA-256 del ZIP final (si llegó a generarse)
  zipSha256      String?       @map("zip_sha256")
  zipByteLength  Int?          @map("zip_byte_length")
  startedAt      DateTime?     @map("started_at")
  finishedAt     DateTime?     @map("finished_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@index([orgId, status])
  @@index([orgId, createdAt])
  @@map("bulk_contract_jobs")
}

// =============================================
// JURISPRUDENCE UPDATE INGESTOR (Generador de Contratos — Chunk 9)
// Cada nueva casación, resolución SUNAFIL o sentencia TC se ingresa como
// una entrada `JurisprudenceUpdate`. Tras revisión humana, "apply" muta
// el catálogo de reglas y cláusulas (chunks 1 y 4) sin requerir redeploy.
// Las instancias firmadas quedan inmutables (versionado del chunk 3).
// Ver docs/specs/contract-generator-spec.md §6 + §12.1.
// =============================================

enum JurisprudenceSource {
  CORTE_SUPREMA
  TRIBUNAL_CONSTITUCIONAL
  SUNAFIL
  MTPE
  OTRO
}

enum JurisprudenceReviewStatus {
  PENDING // Recién ingresada — falta revisión legal
  APPROVED // Validada para apply
  APPLIED // Apply ya ejecutado — afectaciones impactaron BD
  REJECTED // Descartada por el revisor
}

model JurisprudenceUpdate {
  id              String                    @id @default(cuid())
  source          JurisprudenceSource
  reference       String // "Cas. Lab. 8912-2023-Lima", "STC 00797-2022-AA/TC"
  title           String
  publicationDate DateTime                  @map("publication_date")
  topic           String // "DESNATURALIZACION_MODAL" | "TUTELA_GESTANTE" | etc.
  summary         String                    @db.Text
  fullTextUrl     String?                   @map("full_text_url")
  /// Acciones a ejecutar sobre ContractValidationRule cuando se haga apply.
  /// Schema: [{ ruleCode, action: "ADD"|"MODIFY"|"DEPRECATE", ruleSpec?, severity?, version? }]
  affectedRules   Json                      @map("affected_rules")
  /// Acciones a ejecutar sobre ContractClause cuando se haga apply.
  /// Schema: [{ code, action: "ADD"|"MODIFY"|"DEPRECATE", patch? }]
  affectedClauses Json                      @map("affected_clauses")
  reviewStatus    JurisprudenceReviewStatus @default(PENDING) @map("review_status")
  reviewedBy      String?                   @map("reviewed_by")
  reviewedAt      DateTime?                 @map("reviewed_at")
  /// Cuando se aplica: snapshot de las acciones y sus resultados (audit trail).
  applyResult     Json?                     @map("apply_result")
  appliedAt       DateTime?                 @map("applied_at")
  appliedBy       String?                   @map("applied_by")
  notes           String?                   @db.Text
  createdAt       DateTime                  @default(now()) @map("created_at")
  updatedAt       DateTime                  @updatedAt @map("updated_at")

  @@index([source, publicationDate])
  @@index([reviewStatus, createdAt])
  @@index([reference])
  @@map("jurisprudence_updates")
}

// =============================================
// CONTRACT CLAUSE CATALOG (Generador de Contratos — Chunk 4)
// Catálogo modular de cláusulas potestativas + causas objetivas blindadas.
// El contenido vive como DATOS (bodyTemplate con {{placeholders}}) →
// nuevas casaciones se aplican como migraciones de seed sin redeploy.
// Ver docs/specs/contract-generator-spec.md §5.2 y §15.
// =============================================

model ContractClause {
  id           String   @id @default(cuid())
  code         String   @unique // "CONF-001", "NOC-001", "PDP-001", "CO-INI-001", etc.
  category     String // "POTESTATIVA" | "CAUSA_OBJETIVA" | "OBLIGATORIA"
  type         String // "CONFIDENCIALIDAD" | "NO_COMPETENCIA" | "IP" | "PDP" | "EXCLUSIVIDAD" | "PERMANENCIA" | "JORNADA_ATIPICA" | "TELETRABAJO" | "CAUSA_OBJETIVA_INICIO" | "CAUSA_OBJETIVA_SUPLENCIA"
  title        String
  bodyTemplate String   @db.Text // texto con {{placeholders}}
  legalBasis   String   @db.Text // "Arts. 122-123 D.Leg. 823 + Cas. Lab. 11259-2017-Lima"
  variables    Json // [{key, label, default, helpText, required, type}]
  applicableTo Json? // { contractTypes?: ContractType[], regimes?: RegimenLaboral[] }
  active       Boolean  @default(true)
  version      String   @default("1.0.0")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([category, active])
  @@index([type])
  @@map("contract_clauses")
}

// =============================================
// CONTRACT VERSIONING (Generador de Contratos — Chunk 3)
// Hash-chain SHA-256 por contrato. Cada edición que toca el contenido
// crea una versión nueva con prevHash apuntando a la anterior. Esto da
// inmutabilidad criptográfica: si una versión histórica es alterada en
// BD, la verificación de cadena lo detecta. Preparado para anclaje
// posterior (Merkle diario + RFC 3161 + OpenTimestamps).
// Ver docs/specs/contract-generator-spec.md §10.
// =============================================

model ContractVersion {
  id            String   @id @default(cuid())
  orgId         String   @map("org_id") // denormalizado: filtro por tenant
  contractId    String   @map("contract_id")
  contract      Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  versionNumber Int      @map("version_number") // 1, 2, 3... por contrato

  // Snapshot del contenido al momento de esta versión
  contentHtml String? @map("content_html") @db.Text
  contentJson Json?   @map("content_json")
  formData    Json?   @map("form_data")

  // Hash chain (blockchain-style). Genesis prevHash = "0x" + "0"*64.
  contentSha256 String @map("content_sha256") // SHA-256 del contenido canonicalizado
  prevHash      String @map("prev_hash") // versionHash de la versión anterior
  versionHash   String @map("version_hash") // SHA-256(content || prev || canonicalJSON(meta))

  // Diff y trazabilidad
  diffJson     Json?   @map("diff_json") // RFC 6902 JSON Patch vs versión anterior
  diffSummary  String? @map("diff_summary") @db.Text // resumen humano legible
  changeReason String  @map("change_reason") @db.Text // por qué cambió
  changedBy    String  @map("changed_by") // userId

  // Anclaje externo (chunk 8) — null hasta que el cron diario procese.
  merkleAnchorId String?       @map("merkle_anchor_id")
  merkleAnchor   MerkleAnchor? @relation(fields: [merkleAnchorId], references: [id])
  /// Índice de la hoja dentro del árbol del día.
  leafIndex      Int?          @map("leaf_index")
  /// Camino de pruebas (siblings hashes ordenados desde la hoja a la raíz).
  /// Schema: [{ hash: "...", side: "L"|"R" }]. Permite verificar que
  /// `versionHash` está incluido en `MerkleAnchor.merkleRoot` sin recargar todo.
  merkleProof    Json?         @map("merkle_proof")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([contractId, versionNumber])
  @@index([orgId, contractId])
  @@index([versionHash])
  @@index([contractId, createdAt])
  @@index([merkleAnchorId])
  @@map("contract_versions")
}

// =============================================
// LEGAL ENGINE: NORMS & RULES
// =============================================

model LegalNorm {
  id          String       @id @default(cuid())
  code        String       @unique // "DL-728", "LEY-29783"
  title       String
  bodyText    String?      @map("body_text")
  category    NormCategory
  publishedAt DateTime?    @map("published_at")
  effectiveAt DateTime?    @map("effective_at")
  repealedAt  DateTime?    @map("repealed_at")
  sourceUrl   String?      @map("source_url")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  rules  LegalRule[]
  alerts NormAlert[]

  @@index([category])
  @@map("legal_norms")
}

enum NormCategory {
  LABORAL
  SUNAFIL
  SEGURIDAD_SALUD
  TRIBUTARIO
  PROCESAL
  GENERAL
}

model LegalRule {
  id            String     @id @default(cuid())
  normId        String     @map("norm_id")
  ruleKey       String     @unique @map("rule_key") // "indemnizacion_despido_arbitrario"
  description   String?
  conditionJson Json?      @map("condition_json") // When this rule applies
  formula       String? // "sueldo * 1.5 * anos"
  parameters    Json? // { "tope_anos": 12, "factor": 1.5 }
  outputType    RuleOutput @default(NUMBER) @map("output_type")
  validFrom     DateTime   @default(now()) @map("valid_from")
  validTo       DateTime?  @map("valid_to")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  norm LegalNorm @relation(fields: [normId], references: [id])

  @@index([ruleKey])
  @@map("legal_rules")
}

enum RuleOutput {
  NUMBER
  BOOLEAN
  PERCENTAGE
  TEXT
  CLAUSE
}

// =============================================
// CALCULATIONS
// =============================================

model Calculation {
  id          String          @id @default(cuid())
  orgId       String?         @map("org_id")
  userId      String?         @map("user_id")
  type        CalculationType
  inputsJson  Json            @map("inputs_json")
  resultJson  Json            @map("result_json") // Full breakdown
  totalAmount Decimal?        @map("total_amount") @db.Decimal(12, 2)
  pdfUrl      String?         @map("pdf_url")
  isPublic    Boolean         @default(false) @map("is_public") // Free calc (no auth)
  createdAt   DateTime        @default(now()) @map("created_at")

  organization Organization? @relation(fields: [orgId], references: [id])
  user         User?         @relation(fields: [userId], references: [id])

  @@index([orgId, type])
  @@index([createdAt])
  @@map("calculations")
}

enum CalculationType {
  LIQUIDACION
  CTS
  GRATIFICACION
  INDEMNIZACION
  HORAS_EXTRAS
  VACACIONES
  MULTA_SUNAFIL
  INTERESES_LEGALES
  APORTES_PREVISIONALES
  UTILIDADES
}

// =============================================
// ALERTS
// =============================================

model NormAlert {
  id                    String         @id @default(cuid())
  normId                String         @map("norm_id")
  title                 String
  summary               String
  impactLevel           ImpactLevel    @map("impact_level")
  affectedContractTypes ContractType[] @map("affected_contract_types")
  publishedAt           DateTime       @default(now()) @map("published_at")
  createdAt             DateTime       @default(now()) @map("created_at")

  norm      LegalNorm  @relation(fields: [normId], references: [id])
  orgAlerts OrgAlert[]

  @@index([impactLevel, publishedAt])
  @@map("norm_alerts")
}

enum ImpactLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model OrgAlert {
  id          String      @id @default(cuid())
  orgId       String      @map("org_id")
  normAlertId String      @map("norm_alert_id")
  status      AlertStatus @default(UNREAD)
  createdAt   DateTime    @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id])
  normAlert    NormAlert    @relation(fields: [normAlertId], references: [id])

  @@unique([orgId, normAlertId])
  @@map("org_alerts")
}

enum AlertStatus {
  UNREAD
  READ
  DISMISSED
}

// =============================================
// SUBSCRIPTIONS & PAYMENTS
// =============================================

model Subscription {
  id                     String             @id @default(cuid())
  orgId                  String             @unique @map("org_id")
  plan                   Plan
  status                 SubscriptionStatus @default(ACTIVE)
  paymentProvider        String?            @map("payment_provider") // "culqi" | "stripe"
  externalSubscriptionId String?            @map("external_subscription_id")
  currentPeriodStart     DateTime           @map("current_period_start")
  currentPeriodEnd       DateTime           @map("current_period_end")
  cancelledAt            DateTime?          @map("cancelled_at")
  // Grandfather pricing: si está seteado y > now(), el cliente conserva el
  // precio anterior hasta esa fecha aunque hayamos subido el catálogo PLANS.
  // Se setea automáticamente en clientes activos al deploy de un re-pricing.
  // Snapshot del precio congelado en centavos (PEN).
  pricingFrozenUntil     DateTime?          @map("pricing_frozen_until")
  pricingFrozenAmount    Int?               @map("pricing_frozen_amount")
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id])

  @@map("subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

// =============================================
// COMPLIANCE DIAGNOSTICS (FASE 2)
// =============================================

model ComplianceDiagnostic {
  id               String         @id @default(cuid())
  orgId            String         @map("org_id")
  type             DiagnosticType
  scoreGlobal      Int            @map("score_global") // 0-100
  scoreByArea      Json           @map("score_by_area") // { "contratos": 85, "sst": 60, ... }
  totalMultaRiesgo Decimal        @map("total_multa_riesgo") @db.Decimal(12, 2)
  questionsJson    Json           @map("questions_json") // preguntas y respuestas
  gapAnalysis      Json?          @map("gap_analysis") // brechas priorizadas
  actionPlan       Json?          @map("action_plan") // plan de accion generado
  completedAt      DateTime?      @map("completed_at")
  createdAt        DateTime       @default(now()) @map("created_at")

  organization Organization     @relation(fields: [orgId], references: [id])
  tasks        ComplianceTask[]

  @@index([orgId, createdAt])
  @@index([orgId, type]) // queries filtran por FULL|EXPRESS|SIMULATION
  @@map("compliance_diagnostics")
}

// Tareas accionables derivadas de brechas detectadas en un diagnostico o simulacro.
// Cada task representa una brecha priorizada que alguien debe resolver — con
// responsable opcional, plazo, gravedad y evidencia de subsanacion.
//
// F2.1 del plan maestro: "Boton 'Generar Plan de Accion' que crea tareas en el sistema".
model ComplianceTask {
  id            String               @id @default(cuid())
  orgId         String               @map("org_id")
  diagnosticId  String?              @map("diagnostic_id") // null si creada manualmente
  // Origen dentro del diagnostico (questionId del scorer o solicitudId del simulacro)
  sourceId      String?              @map("source_id")
  area          String // area_key: "sst", "contratos_registro", etc.
  priority      Int                  @default(0) // 1 = mas urgente
  title         String // accion corta: "Implementar IPERC firmado"
  description   String?              @db.Text // accion completa + contexto
  baseLegal     String?              @map("base_legal") // "Ley 29783, Art. 57"
  gravedad      InfracGravedad       @default(LEVE)
  multaEvitable Decimal?             @map("multa_evitable") @db.Decimal(12, 2)
  plazoSugerido String?              @map("plazo_sugerido") // "Inmediato (7 dias)"
  dueDate       DateTime?            @map("due_date")
  assignedTo    String?              @map("assigned_to") // userId del responsable
  status        ComplianceTaskStatus @default(PENDING)
  evidenceUrl   String?              @map("evidence_url")
  notes         String?              @db.Text
  completedAt   DateTime?            @map("completed_at")
  completedBy   String?              @map("completed_by") // userId
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  organization Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  diagnostic   ComplianceDiagnostic? @relation(fields: [diagnosticId], references: [id], onDelete: SetNull)

  @@index([orgId, status])
  @@index([orgId, dueDate])
  @@index([diagnosticId])
  @@map("compliance_tasks")
}

enum ComplianceTaskStatus {
  PENDING // Creada, sin asignar
  IN_PROGRESS // En proceso de subsanacion
  COMPLETED // Resuelta con evidencia
  DISMISSED // Descartada (ej. NA para este caso)
}

enum InfracGravedad {
  LEVE
  GRAVE
  MUY_GRAVE
}

enum DiagnosticType {
  FULL // 120 preguntas — diagnostico completo
  EXPRESS // 20 preguntas — rapido mensual
  SIMULATION // Simulacro SUNAFIL interactivo
}

model ComplianceScore {
