  CAMBIO_SUELDO
  CAMBIO_CARGO
  CAMBIO_DEPARTAMENTO
  CAMBIO_REGIMEN
  CAMBIO_TIPO_CONTRATO
  CAMBIO_HORARIO
  CAMBIO_REGIMEN_PREVISIONAL // AFP <-> ONP
  SUSPENSION
  REINCORPORACION
  LICENCIA_MEDICA
  LICENCIA_MATERNIDAD
  LICENCIA_PATERNIDAD
  VACACIONES_INICIO
  VACACIONES_FIN
  CESE
  REINGRESO
  ACTUALIZACION_LEGAJO // dependientes / discapacidad / condición especial
  T_REGISTRO_PRESENTADO
}

enum AlertSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

// =============================================
// CONTRACTS
// =============================================

model ContractTemplate {
  id            String       @id @default(cuid())
  type          ContractType
  name          String
  description   String?
  version       Int          @default(1)
  fieldsSchema  Json         @map("fields_schema") // JSON Schema for dynamic form
  contentBlocks Json         @map("content_blocks") // Template blocks with variables
  legalBasis    String?      @map("legal_basis") // "D.Leg 728, Art. 4"
  isActive      Boolean      @default(true) @map("is_active")
  validFrom     DateTime     @default(now()) @map("valid_from")
  validTo       DateTime?    @map("valid_to")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  contracts Contract[]

  @@map("contract_templates")
}

enum ContractType {
  LABORAL_INDEFINIDO
  LABORAL_PLAZO_FIJO
  LABORAL_TIEMPO_PARCIAL
  LOCACION_SERVICIOS
  CONFIDENCIALIDAD
  NO_COMPETENCIA
  POLITICA_HOSTIGAMIENTO
  POLITICA_SST
  REGLAMENTO_INTERNO
  ADDENDUM
  CONVENIO_PRACTICAS
  CUSTOM
}

model Contract {
  id             String         @id @default(cuid())
  orgId          String         @map("org_id")
  createdById    String         @map("created_by_id")
  templateId     String?        @map("template_id")
  type           ContractType
  status         ContractStatus @default(DRAFT)
  title          String
  formData       Json?          @map("form_data") // User inputs
  contentJson    Json?          @map("content_json") // Generated contract structure
  contentHtml    String?        @map("content_html") // Rendered HTML
  docxUrl        String?        @map("docx_url")
  pdfUrl         String?        @map("pdf_url")
  expiresAt      DateTime?      @map("expires_at")
  signedAt       DateTime?      @map("signed_at")
  aiRiskScore    Int?           @map("ai_risk_score") // 0-100
  aiRisksJson    Json?          @map("ai_risks_json") // Array of detected risks
  aiReviewedAt   DateTime?      @map("ai_reviewed_at")
  provenance     String         @default("LEGACY")
  generationMode String         @default("legacy") @map("generation_mode")
  renderVersion  String?        @map("render_version")
