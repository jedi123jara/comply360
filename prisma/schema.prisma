// =============================================
// CRAWLER NORMATIVO (FASE 4)
// =============================================

model NormUpdate {
  id               String           @id @default(cuid())
  source           NormSource
  externalId       String?          @unique @map("external_id") // ID unico del scraper
  normCode         String           @map("norm_code") // "LEY-32353", "D.S.-014-2025-TR"
  title            String
  summary          String?
  fullText         String?          @map("full_text")
  category         NormCategory
  publishedAt      DateTime?        @map("published_at")
  effectiveAt      DateTime?        @map("effective_at")
  sourceUrl        String?          @map("source_url")
  impactAnalysis   String?          @map("impact_analysis") // analisis IA del impacto
  impactLevel      ImpactLevel?     @map("impact_level")
  affectedModules  String[]         @map("affected_modules") // ["contratos", "sst", "beneficios"]
  affectedRegimens RegimenLaboral[] @map("affected_regimens")
  actionRequired   String?          @map("action_required") // que debe hacer la empresa
  actionDeadline   DateTime?        @map("action_deadline")
  isProcessed      Boolean          @default(false) @map("is_processed")
  // Flujo de aprobacion: el equipo dev revisa antes de publicar
  status           NormStatus       @default(PENDING_REVIEW)
  reviewNotes      String?          @map("review_notes")
  reviewedAt       DateTime?        @map("reviewed_at")
  reviewedBy       String?          @map("reviewed_by") // email del revisor
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  @@index([category, publishedAt])
  @@index([isProcessed])
  @@index([status])
  @@map("norm_updates")
}

enum NormSource {
  EL_PERUANO
  SUNAFIL
  MTPE
  SUNAT
  MANUAL
}

enum NormStatus {
  PENDING_REVIEW // detectada por el crawler, pendiente de revision del equipo dev
  APPROVED       // aprobada y visible para los clientes
  REJECTED       // descartada (duplicado, irrelevante, error del scraper)
}

// =============================================
// PROCESO DE CESE Y LIQUIDACION (D.Leg. 728)
// =============================================

model CeseRecord {
  id                    String      @id @default(cuid())
  orgId                 String      @map("org_id")
  workerId              String      @unique @map("worker_id")

  // Tipo y causa
  tipoCese              TipoCese    @map("tipo_cese")
  causaDetalle          String?     @map("causa_detalle") @db.Text

  // Fechas del proceso
  fechaInicioProceso    DateTime    @map("fecha_inicio_proceso")
  fechaCese             DateTime    @map("fecha_cese")
  fechaCartaPreaviso    DateTime?   @map("fecha_carta_preaviso")
  fechaLimiteDescargos  DateTime?   @map("fecha_limite_descargos")
  fechaCartaDespido     DateTime?   @map("fecha_carta_despido")
  fechaPagoLiquidacion  DateTime?   @map("fecha_pago_liquidacion")

  // Montos de liquidación
  sueldoBruto           Decimal     @map("sueldo_bruto") @db.Decimal(10, 2)
  ctsMonto              Decimal     @default(0) @map("cts_monto") @db.Decimal(10, 2)
  vacacionesMonto       Decimal     @default(0) @map("vacaciones_monto") @db.Decimal(10, 2)
  gratificacionMonto    Decimal     @default(0) @map("gratificacion_monto") @db.Decimal(10, 2)
  indemnizacionMonto    Decimal     @default(0) @map("indemnizacion_monto") @db.Decimal(10, 2)
  totalLiquidacion      Decimal     @default(0) @map("total_liquidacion") @db.Decimal(10, 2)
  detalleJson           Json?       @map("detalle_json")

  // Estado del proceso
  etapa                 EtapaCese   @default(INICIADO)
  observaciones         String?     @db.Text

  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")

  worker Worker @relation(fields: [workerId], references: [id])

  @@index([orgId])
  @@map("cese_records")
}

enum TipoCese {
  RENUNCIA_VOLUNTARIA       // Trabajador renuncia — Art. 18 D.S. 003-97-TR
  DESPIDO_CAUSA_JUSTA       // Falta grave — Art. 22-25 D.Leg. 728
  DESPIDO_ARBITRARIO        // Sin causa justa — indemnización obligatoria
  MUTUO_DISENSO             // Acuerdo ambas partes — Art. 19 D.S. 003-97-TR
  TERMINO_CONTRATO          // Fin de contrato a plazo fijo
  NO_RENOVACION             // No renovación de contrato temporal
  FALLECIMIENTO             // Art. 16.a D.S. 003-97-TR
  JUBILACION                // Art. 16.f D.S. 003-97-TR
  PERIODO_PRUEBA            // Dentro del período de prueba — Art. 10
}

enum EtapaCese {
  INICIADO
  CARTA_PREAVISO
  PERIODO_DESCARGOS
  CARTA_DESPIDO
  LIQUIDACION_CALCULADA
  LIQUIDACION_PAGADA
  COMPLETADO
  ANULADO
}

