generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================
// AUTHENTICATION & ORGANIZATIONS
// =============================================

model Organization {
  id                     String    @id @default(cuid())
  name                   String
  ruc                    String?   @unique
  razonSocial            String?   @map("razon_social")
  nombreComercial        String?   @map("nombre_comercial")
  sector                 String?
  sizeRange              String?   @map("size_range") // 1-10, 11-50, 51-200, 200+
  logoUrl                String?   @map("logo_url")
  plan                   Plan      @default(STARTER)
  planExpiresAt          DateTime? @map("plan_expires_at")
  onboardingCompleted    Boolean   @default(false) @map("onboarding_completed")
  regimenPrincipal       String?   @map("regimen_principal") // GENERAL, MYPE_MICRO, etc.
  regimenTributario      String?   @map("regimen_tributario") // RER, RMT, RG, RUS
  alertEmail             String?   @map("alert_email")
  phone                  String?
  address                String? // direccion fiscal
  city                   String? // departamento
  province               String?
  district               String?
  // Representante Legal
  repNombre              String?   @map("rep_nombre")
  repDni                 String?   @map("rep_dni")
  repCargo               String?   @map("rep_cargo")
  // Contador responsable
  contNombre             String?   @map("cont_nombre")
  contCpc                String?   @map("cont_cpc")
  contEmail              String?   @map("cont_email")
  // ─── Detección de subdeclaración (anti-informalidad) ─────────────────
  // Total de trabajadores que el empleador DECLARA que tiene en total
  // (incluyendo no registrados aún en COMPLY360). Si > workers registrados
  // → brecha = trabajadores fuera de planilla → multa SUNAFIL Art. 24.5
  // D.S. 019-2006-TR. El sistema lo detecta y alerta.
  totalWorkersDeclared   Int?      @map("total_workers_declared")
  totalWorkersDeclaredAt DateTime? @map("total_workers_declared_at")

  // ─── Inputs del detector automático de régimen (Generador / Chunk 2) ─
  // Campos que alimentan src/lib/contracts/regime/detect.ts. Todos
  // opcionales para no romper orgs existentes; el detector cae a "GENERAL"
  // cuando faltan datos y avisa por warnings.
  ciiu                  String?      @map("ciiu") // CIIU rev. 4 a 4 dígitos: ej. "4100" construcción
  ubigeo                String?      @map("ubigeo") // 6 dígitos INEI: dept(2)+prov(2)+dist(2)
  annualSalesPEN        Decimal?     @map("annual_sales_pen") @db.Decimal(14, 2) // ventas anuales
  groupAnnualSalesPEN   Decimal?     @map("group_annual_sales_pen") @db.Decimal(14, 2) // grupo económico vinculado
  isPartOfBigGroup      Boolean      @default(false) @map("is_part_of_big_group") // Ley 32353 — vinculados que en consolidado superan 1700 UIT
  remypeRegistered      Boolean      @default(false) @map("remype_registered") // inscripción REMYPE habilitante
  exportRatioPct        Decimal?     @map("export_ratio_pct") @db.Decimal(5, 2) // % exportación 0-100
  currentProjectCostUIT Decimal?     @map("current_project_cost_uit") @db.Decimal(10, 2) // costo de obra en UIT (construcción civil > 50 UIT)
  employerType          EmployerType @default(LEGAL_PERSON) @map("employer_type")
  domesticPurpose       Boolean      @default(false) @map("domestic_purpose") // empleador persona natural con propósito doméstico → Ley 31047
  usesAgroInputs        Boolean      @default(false) @map("uses_agro_inputs") // agroindustria con insumos agropecuarios → Ley 31110
  isPublicEntity        Boolean      @default(false) @map("is_public_entity") // entidad pública → capa Huatuco

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users                   User[]
  workers                 Worker[]
  contracts               Contract[]
  calculations            Calculation[]
  orgAlerts               OrgAlert[]
  auditLogs               AuditLog[]
  subscription            Subscription?
  diagnostics             ComplianceDiagnostic[]
  complianceTasks         ComplianceTask[]
  complaints              Complaint[]
  invitations             Invitation[]
  payslips                Payslip[]
  workerRequests          WorkerRequest[]
  documents               OrgDocument[]
  orgTemplates            OrgTemplate[]
  documentAcknowledgments DocumentAcknowledgment[]
  serviceProviders        ServiceProvider[]
  rhInvoices              RhInvoice[]
  inspecciones            InspeccionEnVivo[]
  ownedClients            ConsultorClient[]        @relation("ConsultorOwner")
  managedBy               ConsultorClient[]        @relation("ConsultorManaged")
  integrationCredentials  IntegrationCredential[]
  // Organigrama
  orgUnits                OrgUnit[]
  orgPositions            OrgPosition[]
  orgAssignments          OrgAssignment[]
  orgComplianceRoles      OrgComplianceRole[]
  orgChartSnapshots       OrgChartSnapshot[]
  orgChartDrafts          OrgChartDraft[]
  orgStructureChangeLogs  OrgStructureChangeLog[]
  // Fase 5 — SST Premium
  sedes                   Sede[]
  iperBases               IPERCBase[]
  accidentes              Accidente[]
  comitesSst              ComiteSST[]
  visitasFieldAudit       VisitaFieldAudit[]
  emos                    EMO[]
  consentimientosLey29733 ConsentimientoLey29733[]
  solicitudesArco         SolicitudARCO[]

  @@map("organizations")
}

// Credenciales de integración encriptadas (SUNAT SOL, etc.)
model IntegrationCredential {
  id              String    @id @default(cuid())
  orgId           String    @map("org_id")
  provider        String // "sunat_sol", "sunat_api", etc.
  label           String? // "SUNAT RUC 20505897867"
  encryptedConfig String    @map("encrypted_config") @db.Text // JSON encriptado con AES-256-GCM
  isActive        Boolean   @default(true) @map("is_active")
  lastTestedAt    DateTime? @map("last_tested_at")
  lastSyncAt      DateTime? @map("last_sync_at")
  lastSyncResult  Json?     @map("last_sync_result") // { success, discrepancies, timestamp }
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, provider])
  @@map("integration_credentials")
}

enum Plan {
  FREE
  STARTER
  EMPRESA
  PRO
  BUSINESS
  ENTERPRISE
}

enum EmployerType {
  NATURAL_PERSON // Persona natural — habilita régimen Trabajo del Hogar (Ley 31047) si propósito doméstico
  LEGAL_PERSON // Persona jurídica (default, mayoría de tenants)
}

model User {
  id               String    @id @default(cuid())
  clerkId          String    @unique @map("clerk_id")
  orgId            String?   @map("org_id")
  email            String    @unique
  firstName        String?   @map("first_name")
  lastName         String?   @map("last_name")
  role             UserRole  @default(MEMBER)
  avatarUrl        String?   @map("avatar_url")
  // Web Push subscription (Fase D). JSON con { endpoint, keys.p256dh, keys.auth }.
  pushSubscription Json?     @map("push_subscription")
  // Gamificación — Fase D Sprint 5
  streakCurrent    Int       @default(0) @map("streak_current")
  streakLongest    Int       @default(0) @map("streak_longest")
  streakLastAt     DateTime? @map("streak_last_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  organization         Organization?       @relation(fields: [orgId], references: [id])
  worker               Worker? // Si el User tiene rol WORKER, su perfil de trabajador
  contracts            Contract[]          @relation("CreatedBy")
  calculations         Calculation[]
  auditLogs            AuditLog[]
  workerRequests       WorkerRequest[]     @relation("RequestReviewer")
  gamificationEvents   GamificationEvent[]
  // Fase 5 — SST Premium (DPO designado por org para responder solicitudes ARCO)
  solicitudesArcoAsDpo SolicitudARCO[]     @relation("DpoAsignado")

  @@map("users")
}

// Gamificación — eventos que suman puntos y desbloquean logros
model GamificationEvent {
  id        String                @id @default(cuid())
  userId    String                @map("user_id")
  orgId     String?               @map("org_id")
  type      GamificationEventType
  points    Int                   @default(0)
  metadata  Json?
  createdAt DateTime              @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([orgId, type])
  @@map("gamification_events")
}

enum GamificationEventType {
  WORKER_CREATED
  DOCUMENT_UPLOADED
  ALERT_RESOLVED
  DIAGNOSTIC_COMPLETED
  SIMULACRO_COMPLETED
  CONTRACT_SIGNED
  DAILY_STREAK
  BADGE_UNLOCKED
  SCORE_MILESTONE
}

enum UserRole {
  SUPER_ADMIN // Dueños de la plataforma — acceso global a todas las organizaciones
  OWNER // Dueño de la organización (empresa cliente)
  ADMIN // Administrador con permisos amplios dentro de la org
  MEMBER // Miembro con acceso operativo
  VIEWER // Solo lectura
  WORKER // Trabajador con acceso a su portal personal (sin acceso al dashboard de gestión)
}

model Invitation {
  id        String   @id @default(cuid())
  orgId     String   @map("org_id")
  email     String
  role      UserRole @default(MEMBER)
  token     String   @unique
  status    String   @default("PENDING")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, email])
  @@map("invitations")
}

// =============================================
// WORKERS (FASE 1 — Modulo central)
// =============================================

model Worker {
  id                      String         @id @default(cuid())
  orgId                   String         @map("org_id")
  userId                  String?        @unique @map("user_id") // Opcional — vincula con User cuando el trabajador activa su portal
  // Datos personales
  dni                     String
  firstName               String         @map("first_name")
  lastName                String         @map("last_name")
  email                   String?
  phone                   String?
  birthDate               DateTime?      @map("birth_date")
  gender                  String?
  nationality             String?        @default("peruana")
  address                 String?
  // Datos laborales
  position                String?
  department              String?
  regimenLaboral          RegimenLaboral @default(GENERAL) @map("regimen_laboral")
  tipoContrato            TipoContrato   @default(INDEFINIDO) @map("tipo_contrato")
  fechaIngreso            DateTime       @map("fecha_ingreso")
  fechaCese               DateTime?      @map("fecha_cese")
  motivoCese              String?        @map("motivo_cese")
  sueldoBruto             Decimal        @map("sueldo_bruto") @db.Decimal(10, 2)
  asignacionFamiliar      Boolean        @default(false) @map("asignacion_familiar")
  jornadaSemanal          Int            @default(48) @map("jornada_semanal")
  tiempoCompleto          Boolean        @default(true) @map("tiempo_completo")
  // Horario laboral pactado (R.M. 037-2024-TR exige documentar política de
  // entrada/salida y tolerancia). Defaults conservadores: 8:00-17:00 con 15
  // min de tolerancia. Si la org tiene turnos distintos, se editan por worker
  // o vía bulk action "Asignar horario".
  expectedClockInHour     Int            @default(8) @map("expected_clock_in_hour")
  expectedClockInMinute   Int            @default(0) @map("expected_clock_in_minute")
  expectedClockOutHour    Int            @default(17) @map("expected_clock_out_hour")
  expectedClockOutMinute  Int            @default(0) @map("expected_clock_out_minute")
  lateToleranceMinutes    Int            @default(15) @map("late_tolerance_minutes")
  // Previsional
  tipoAporte              TipoAporte     @default(AFP) @map("tipo_aporte")
  afpNombre               String?        @map("afp_nombre")
  afpComisionTipo         String?        @map("afp_comision_tipo") // "MIXTA" | "FLUJO"
  cuspp                   String?
  essaludVida             Boolean        @default(false) @map("essalud_vida")
  sctr                    Boolean        @default(false)
  sctrRiesgoNivel         String?        @map("sctr_riesgo_nivel") // "BAJO" | "MEDIO" | "ALTO" — para sectores Ley 26790
  // Condiciones especiales (peruanas)
  // Ley 29973 — cuota 3% de personas con discapacidad. Reportable a SUNAFIL.
  discapacidad            Boolean        @default(false)
  discapacidadTipo        String?        @map("discapacidad_tipo") // "FISICA" | "SENSORIAL" | "INTELECTUAL" | "PSICOSOCIAL" | "MULTIPLE"
  // Tipo de jornada — afecta cálculo de horas extras (D.Leg. 854: 25% día, 35% noche)
  tipoJornada             String         @default("DIURNO") @map("tipo_jornada") // "DIURNO" | "NOCTURNO" | "MIXTO"
  // PIN 4 dígitos para asistencia sin smartphone (backup del flujo QR).
  // Generado automáticamente al onboarding del worker. Se envía por email.
  attendancePin           String?        @map("attendance_pin") // hash bcrypt del PIN
  // ─── Personalización del worker (subido desde el portal) ────────────
  // Foto subida por el trabajador desde /mi-portal/perfil. Si null, el
  // admin ve solo las iniciales como avatar.
  photoUrl                String?        @map("photo_url")
  // Bio breve / hobby / fun fact (max 200 chars). Humaniza el card del
  // admin: en lugar de solo nombre+cargo, ve "Le encanta la cocina coreana".
  bio                     String?
  // Compliance peruano adicional (Ola 2 — 2026-05)
  numeroEssalud           String?        @map("numero_essalud")
  tipoSangre              String?        @map("tipo_sangre") // "ORH+" | "ORH-" | "ARH+" | etc.
  nivelEducativo          String?        @map("nivel_educativo") // PRIMARIA | SECUNDARIA | TECNICA | UNIVERSITARIA | POSTGRADO
  condicionEspecial       String?        @map("condicion_especial") // EMBARAZADA | LACTANCIA | MATERNIDAD_EXTENDIDA | NINGUNA
  discapacidadCertificado Boolean        @default(false) @map("discapacidad_certificado") // CONADIS acreditado (Ley 29973 cuota 3%)
  conadisCertificadoNum   String?        @map("conadis_certificado_num")
  // Flags de cumplimiento operacional (alertas SUNAFIL específicas)
  flagTRegistroPresentado Boolean        @default(false) @map("flag_t_registro_presentado") // T-REGISTRO SUNAT (1 día hábil del ingreso)
  flagTRegistroFecha      DateTime?      @map("flag_t_registro_fecha")

  // Estado
  status       WorkerStatus @default(ACTIVE)
  legajoScore  Int?         @map("legajo_score")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  // Soft delete (Ola 1 — compliance SUNAFIL exige trazabilidad 6 años)
  deletedAt    DateTime?    @map("deleted_at")
  deletedBy    String?      @map("deleted_by")
  deleteReason String?      @map("delete_reason")

  organization            Organization             @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user                    User?                    @relation(fields: [userId], references: [id])
  documents               WorkerDocument[]
  workerContracts         WorkerContract[]
  vacations               VacationRecord[]
  alerts                  WorkerAlert[]
  attendance              Attendance[]
  payslips                Payslip[]
  requests                WorkerRequest[]
  ceseRecord              CeseRecord?
  acknowledgments         DocumentAcknowledgment[]
  orgAssignments          OrgAssignment[]
  orgComplianceRoles      OrgComplianceRole[]
  // Ola 1 — dependientes (asignación familiar real con DNI)
  dependents              WorkerDependent[]
  // Ola 2 — historial estructurado de cambios laborales
  historyEvents           WorkerHistoryEvent[]
  // Fase 5 — SST Premium
  puestosTrabajo          PuestoTrabajo[]
  accidentes              Accidente[]
  miembroComites          MiembroComite[]
  emos                    EMO[]
  consentimientosLey29733 ConsentimientoLey29733[]

  @@unique([orgId, dni])
  @@index([orgId, status])
  @@index([orgId, regimenLaboral])
  @@index([orgId, deletedAt]) // listas activas filtran rápido por deletedAt IS NULL
  @@map("workers")
}

enum RegimenLaboral {
  GENERAL
  MYPE_MICRO
  MYPE_PEQUENA
  AGRARIO
  CONSTRUCCION_CIVIL
  MINERO
  PESQUERO
  TEXTIL_EXPORTACION
  DOMESTICO
  CAS
  MODALIDAD_FORMATIVA
  TELETRABAJO
}

enum TipoContrato {
  INDEFINIDO
  PLAZO_FIJO
  TIEMPO_PARCIAL
  INICIO_ACTIVIDAD
  NECESIDAD_MERCADO
  RECONVERSION
  SUPLENCIA
  EMERGENCIA
  OBRA_DETERMINADA
  INTERMITENTE
  EXPORTACION
}

enum TipoAporte {
  AFP
  ONP
  SIN_APORTE
}

enum WorkerStatus {
  ACTIVE
  ON_LEAVE
  SUSPENDED
  TERMINATED
}

model WorkerDocument {
  id           String      @id @default(cuid())
  workerId     String      @map("worker_id")
  category     DocCategory
  documentType String      @map("document_type")
  title        String
  fileUrl      String?     @map("file_url")
  fileSize     Int?        @map("file_size")
  mimeType     String?     @map("mime_type")
  isRequired   Boolean     @default(false) @map("is_required")
  expiresAt    DateTime?   @map("expires_at")
  verifiedAt   DateTime?   @map("verified_at")
  verifiedBy   String?     @map("verified_by")
  status       DocStatus   @default(PENDING)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId, category])
  @@index([expiresAt])
  @@map("worker_documents")
}

enum DocCategory {
  INGRESO
  VIGENTE
  SST
  PREVISIONAL
  CESE
}

enum DocStatus {
  PENDING
  UPLOADED
  VERIFIED
  EXPIRED
  MISSING
}

model VacationRecord {
  id               String    @id @default(cuid())
  workerId         String    @map("worker_id")
  periodoInicio    DateTime  @map("periodo_inicio")
  periodoFin       DateTime  @map("periodo_fin")
  diasCorresponden Int       @default(30) @map("dias_corresponden")
  diasGozados      Int       @default(0) @map("dias_gozados")
  diasPendientes   Int       @default(30) @map("dias_pendientes")
  fechaGoce        DateTime? @map("fecha_goce")
  esDoble          Boolean   @default(false) @map("es_doble")
  createdAt        DateTime  @default(now()) @map("created_at")

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId])
  @@map("vacation_records")
}

model WorkerContract {
  id         String   @id @default(cuid())
  workerId   String   @map("worker_id")
  contractId String   @map("contract_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  worker   Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  contract Contract @relation(fields: [contractId], references: [id])

  @@unique([workerId, contractId])
  @@index([workerId])
  @@index([contractId])
  @@map("worker_contracts")
}

model WorkerAlert {
  id            String          @id @default(cuid())
  workerId      String          @map("worker_id")
  orgId         String          @map("org_id")
  type          WorkerAlertType
  severity      AlertSeverity
  title         String
  description   String?
  dueDate       DateTime?       @map("due_date")
  multaEstimada Decimal?        @map("multa_estimada") @db.Decimal(10, 2)
  resolvedAt    DateTime?       @map("resolved_at")
  resolvedBy    String?         @map("resolved_by")
  createdAt     DateTime        @default(now()) @map("created_at")

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([orgId, severity])
  @@index([orgId, resolvedAt]) // hot path: filtro resolvedAt IS NULL (12 archivos)
  @@index([dueDate])
  @@map("worker_alerts")
}

enum WorkerAlertType {
  CONTRATO_POR_VENCER
  CONTRATO_VENCIDO
  CTS_PENDIENTE
  GRATIFICACION_PENDIENTE
  VACACIONES_ACUMULADAS
  VACACIONES_DOBLE_PERIODO
  DOCUMENTO_FALTANTE
  DOCUMENTO_VENCIDO
  DOCUMENTO_SOSPECHOSO // IA visión detectó posible manipulación
  EXAMEN_MEDICO_VENCIDO
  CAPACITACION_PENDIENTE
  AFP_EN_MORA
  REGISTRO_INCOMPLETO
  // Patrones de asistencia detectados por scan periódico (Fase 3)
  TARDANZAS_CRONICAS // 5+ tardanzas en 15 días sin justificar
  AUSENTISMO_CRONICO // 3+ ausencias sin justificar en el mes
  // Fase 5 — SST Premium
  IPERC_VENCIDO
  EMO_PROXIMO
  EMO_VENCIDO
  SAT_PLAZO_PROXIMO
  SAT_PLAZO_VENCIDO
  COMITE_REUNION_PENDIENTE
  COMITE_MANDATO_VENCE
  SIMULACRO_PENDIENTE
  // Ola 1 — Compliance SUNAFIL hardening (2026-05)
  T_REGISTRO_NO_PRESENTADO // 1 día hábil tras ingreso sin marca en SUNAT
  SCTR_VENCIDO // SCTR vencido en sectores de riesgo (construcción/minería/pesca)
  CAMBIO_REGIMEN_SIN_ADENDA // Cambio de régimen detectado sin adenda firmada
  LICENCIA_MEDICA_VENCIDA // Descanso médico expirado sin renovación
}

// ─── WorkerDependent ──────────────────────────────────────────────────────────
// Ola 1 — Dependientes acreditados para asignación familiar (Ley 25129) y
// derecho-habientes EsSalud (Ley 27657). Sin esta tabla, `Worker.asignacionFamiliar`
// es un boolean declarativo sin DNI cruzable → multa SUNAFIL 23.11 UIT por
// asignación falsa.
model WorkerDependent {
  id                    String            @id @default(cuid())
  workerId              String            @map("worker_id")
  orgId                 String            @map("org_id") // denormalizado para RLS y queries rápidas
  relacion              DependentRelation
  documentoTipo         String            @default("DNI") @map("documento_tipo") // DNI | CE | PASAPORTE | PARTIDA_NACIMIENTO
  documentoNum          String            @map("documento_num")
  fullName              String            @map("full_name")
  birthDate             DateTime          @map("birth_date")
  actaUrl               String?           @map("acta_url") // URL partida nacimiento / matrimonio
  esBeneficiarioEsalud  Boolean           @default(true) @map("es_beneficiario_esalud")
  esBeneficiarioAsigFam Boolean           @default(false) @map("es_beneficiario_asig_fam") // ¿este dependiente justifica asignación familiar?
  verifiedAt            DateTime?         @map("verified_at")
  verifiedBy            String?           @map("verified_by")
  notas                 String?
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  deletedAt             DateTime?         @map("deleted_at")

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([workerId, documentoTipo, documentoNum])
  @@index([workerId, deletedAt])
  @@index([orgId])
  @@map("worker_dependents")
}

enum DependentRelation {
  CONYUGE
  CONVIVIENTE // Unión de hecho Ley 30007
  HIJO
  HIJO_ADOPTIVO
  HIJO_DISCAPACITADO // Sin límite de edad para EsSalud
  PADRE
  MADRE
  HERMANO_DISCAPACITADO // Si depende económicamente
  OTRO
}

// ─── WorkerHistoryEvent ───────────────────────────────────────────────────────
// Ola 2 — Historial estructurado de cambios laborales. SUNAFIL exige trazabilidad
// de modificaciones contractuales (D.S. 019-2006-TR Art. 24). Cambios de sueldo,
// cargo, régimen o tipo de contrato sin acta = desnaturalización.
model WorkerHistoryEvent {
  id          String          @id @default(cuid())
  workerId    String          @map("worker_id")
  orgId       String          @map("org_id")
  type        WorkerEventType
  before      Json? // snapshot del/los campo(s) antes
  after       Json? // snapshot del/los campo(s) después
  reason      String? // motivo declarado por el admin
  evidenceUrl String?         @map("evidence_url") // adenda firmada / acta / carta
  triggeredBy String          @map("triggered_by") // userId del admin
  createdAt   DateTime        @default(now()) @map("created_at")

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId, createdAt])
  @@index([orgId, type])
  @@index([orgId, createdAt]) // gating por plan filtra por fecha
  @@map("worker_history_events")
}

enum WorkerEventType {
