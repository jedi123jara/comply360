// =============================================
// SERVICE PROVIDERS (4ta categoria / Recibos por Honorarios)
// =============================================
// Prestadores de servicios independientes que emiten RH.
// Regidos por el Codigo Civil (Art. 1764 — Locacion de Servicios), NO por el D.Leg. 728.
// NO tienen CTS, gratificaciones, vacaciones ni asignacion familiar.
// Retencion 8% IR 4ta categoria si > 1/7 UIT mensual y sin constancia de suspension.
// Riesgo principal: DESNATURALIZACION (reclasificacion a 5ta por SUNAFIL si hay subordinacion).

model ServiceProvider {
  id             String  @id @default(cuid())
  orgId          String  @map("org_id")
  // Identificacion
  documentType   String  @default("DNI") @map("document_type") // DNI, CE, RUC, PASAPORTE
  documentNumber String  @map("document_number")
  ruc            String? // RUC del prestador (obligatorio para emitir RH electronico)
  firstName      String  @map("first_name")
  lastName       String  @map("last_name")
  email          String?
  phone          String?
  address        String?
  profession     String? // Profesion/especialidad (ej: Contador, Ingeniero, Diseñador)
  // Servicio contratado
  servicioDescripcion String    @map("servicio_descripcion") // Descripcion breve del servicio
  area                String? // Area de la empresa donde presta servicio
  startDate           DateTime  @map("start_date") // Inicio del servicio
  endDate             DateTime? @map("end_date") // Fin previsto (si hay)
  monthlyAmount       Decimal   @map("monthly_amount") @db.Decimal(10, 2) // Monto mensual acordado
  currency            String    @default("PEN")
  paymentFrequency    String    @default("MONTHLY") @map("payment_frequency") // MONTHLY, BIWEEKLY, PROJECT, HOURLY
  // Retencion de 4ta categoria
  hasSuspensionRetencion Boolean   @default(false) @map("has_suspension_retencion") // Constancia vigente de SUNAT
  suspensionExpiryDate   DateTime? @map("suspension_expiry_date") // Vence cada 31 de diciembre
  // Analisis de riesgo de desnaturalizacion (indicadores laborales)
  hasFixedSchedule      Boolean @default(false) @map("has_fixed_schedule") // Horario fijo impuesto
  hasExclusivity        Boolean @default(false) @map("has_exclusivity") // Exclusividad con la empresa
  worksOnPremises       Boolean @default(false) @map("works_on_premises") // Trabaja dentro de las instalaciones
  usesCompanyTools      Boolean @default(false) @map("uses_company_tools") // Usa equipos/herramientas de la empresa
  reportsToSupervisor   Boolean @default(false) @map("reports_to_supervisor") // Tiene jefe directo
  receivesOrders        Boolean @default(false) @map("receives_orders") // Recibe ordenes directas
  desnaturalizacionRisk Int     @default(0) @map("desnaturalizacion_risk") // 0-100 calculado desde los flags
  // Documentacion
  contractFileUrl String? @map("contract_file_url") // PDF del contrato de locacion de servicios
  // Estado
  status    ServiceProviderStatus @default(ACTIVE)
  notes     String?
  createdAt DateTime              @default(now()) @map("created_at")
  updatedAt DateTime              @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id])
  rhInvoices   RhInvoice[]

  @@unique([orgId, documentNumber])
  @@index([orgId, status])
  @@map("service_providers")
}

enum ServiceProviderStatus {
  ACTIVE
  INACTIVE
  TERMINATED
  AT_RISK // Riesgo alto de desnaturalizacion
}

model RhInvoice {
  id            String    @id @default(cuid())
  orgId         String    @map("org_id")
  providerId    String    @map("provider_id")
  invoiceNumber String    @map("invoice_number") // E001-123 o similar
  issueDate     DateTime  @map("issue_date")
  periodo       String // YYYY-MM — mes de servicio prestado
  grossAmount   Decimal   @map("gross_amount") @db.Decimal(10, 2)
  retention     Decimal   @default(0) @db.Decimal(10, 2) // 8% IR si aplica
  netAmount     Decimal   @map("net_amount") @db.Decimal(10, 2)
  hasRetention  Boolean   @default(false) @map("has_retention")
  status        String    @default("PENDING") // PENDING, PAID, CANCELLED
  paidAt        DateTime? @map("paid_at")
  fileUrl       String?   @map("file_url") // PDF del recibo electronico
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  organization Organization    @relation(fields: [orgId], references: [id])
  provider     ServiceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([orgId, periodo])
  @@index([providerId, issueDate])
  @@map("rh_invoices")
}

// =============================================
// INSPECCION EN VIVO — "MODO CRISIS" SUNAFIL
// =============================================

// =============================================
// PORTAL CONTADOR — Multi-org management
// A "consultor" (accountant / labor advisor) manages multiple client orgs
// =============================================

model ConsultorClient {
  id              String   @id @default(cuid())
  /// Clerk userId of the consultor (not linked as FK to avoid Clerk coupling)
  consultorUserId String   @map("consultor_user_id")
  /// The consultor's own org (the accounting firm or consultancy)
  consultorOrgId  String   @map("consultor_org_id")
  /// The client org being managed
  clientOrgId     String   @map("client_org_id")
  /// Cached display name — denormalized for fast list rendering
  clientOrgName   String?  @map("client_org_name")
  clientRuc       String?  @map("client_ruc")
  isActive        Boolean  @default(true) @map("is_active")
  notes           String?
  addedAt         DateTime @default(now()) @map("added_at")

  consultorOrg Organization @relation("ConsultorOwner", fields: [consultorOrgId], references: [id])
  clientOrg    Organization @relation("ConsultorManaged", fields: [clientOrgId], references: [id])

  @@unique([consultorUserId, clientOrgId])
  @@index([consultorUserId, isActive])
  @@index([consultorOrgId])
  @@map("consultor_clients")
}

model InspeccionEnVivo {
  id              String    @id @default(cuid())
  orgId           String    @map("org_id")
  tipo            String    // PREVENTIVA, POR_DENUNCIA, PROGRAMA_SECTORIAL
  status          String    @default("ACTIVE") // ACTIVE, PAUSED, COMPLETED
  inspectorName   String?   @map("inspector_name")
  inspectorDNI    String?   @map("inspector_dni")
  ordenInspeccion String?   @map("orden_inspeccion")
  startedAt       DateTime  @default(now()) @map("started_at")
  completedAt     DateTime? @map("completed_at")
  hallazgosJson   Json?     @map("hallazgos_json") // Array of HallazgoInspeccion
  resultadoJson   Json?     @map("resultado_json") // ResultadoSimulacro
  evidenciasJson  Json?     @map("evidencias_json") // { solicitudId: [url1, url2] }
  multaEstimada   Decimal?  @map("multa_estimada") @db.Decimal(12, 2)
  scoreInspeccion Int?      @map("score_inspeccion") // 0-100
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id])

  @@index([orgId, status])
  @@index([orgId, createdAt])
  @@map("inspecciones_en_vivo")
}

// =============================================
// LEADS — Captura de prospectos (diagnóstico gratis, landing, etc.)
// =============================================

model Lead {
  id             String     @id @default(cuid())
  email          String
  companyName    String?    @map("company_name")
  companySize    String?    @map("company_size") // 1-10, 11-50, 51-200, 200+
  sector         String?
  phone          String?
  source         LeadSource @default(DIAGNOSTICO_GRATIS)
  // Diagnóstico express results (if applicable)
  scoreGlobal    Int?       @map("score_global")
  multaEstimada  Decimal?   @map("multa_estimada") @db.Decimal(12, 2)
  scoreByArea    Json?      @map("score_by_area")
  // Tracking
  convertedAt    DateTime?  @map("converted_at") // cuando se registra como usuario
  convertedOrgId String?    @map("converted_org_id")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  @@index([email])
  @@index([source, createdAt])
  @@map("leads")
}

enum LeadSource {
  DIAGNOSTICO_GRATIS
  LANDING_PAGE
  REFERRAL
  WEBINAR
  MANUAL
}

// =============================================
// SUNAT QUERY CACHE
// =============================================

model SunatQueryCache {
  id         String   @id @default(cuid())
  orgId      String?  @map("org_id")
  ruc        String
  queryType  String   @map("query_type") // "deuda", "representantes", "trabajadores", "establecimientos"
  resultJson Json     @map("result_json")
  queriedAt  DateTime @default(now()) @map("queried_at")
  expiresAt  DateTime @map("expires_at")

  @@index([ruc, queryType])
  @@index([expiresAt])
  @@map("sunat_query_cache")
}

